---
/**
 * ReadingProgress — Thin progress bar fixed at the top of the viewport.
 * Fills left-to-right as the user scrolls through the article.
 * Pure vanilla JS, no framework dependency.
 */
---

<div class="reading-progress" id="reading-progress" aria-hidden="true">
  <div class="reading-progress__bar" id="reading-progress-bar"></div>
</div>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    z-index: 1000;
    background: transparent;
    pointer-events: none;
  }
  .reading-progress__bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--mc-green, #2D4A22), var(--mc-green-mid, #3D6B2E), var(--mc-amber, #D4A017));
    border-radius: 0 2px 2px 0;
    transition: none;
    will-change: width;
  }
</style>

<script is:inline>
(function () {
  var bar = document.getElementById('reading-progress-bar');
  if (!bar) return;

  var ticking = false;

  function updateProgress() {
    var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    var docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    if (docHeight <= 0) { bar.style.width = '0%'; return; }
    var pct = Math.min(100, Math.max(0, (scrollTop / docHeight) * 100));
    bar.style.width = pct + '%';
    ticking = false;
  }

  window.addEventListener('scroll', function () {
    if (!ticking) {
      requestAnimationFrame(updateProgress);
      ticking = true;
    }
  }, { passive: true });

  updateProgress();
})();
</script>
