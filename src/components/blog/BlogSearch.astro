---
export interface SearchPost {
  title: string;
  description: string;
  slug: string;
  image: string;
  category: string;
  tags: string[];
}

export interface Props {
  posts: SearchPost[];
  lang: string;
}

const { posts, lang } = Astro.props;

const placeholders: Record<string, string> = {
  en: 'Search articles...',
  es: 'Buscar artículos...',
  de: 'Artikel suchen...',
  fr: 'Rechercher des articles...',
};

const noResultsText: Record<string, string> = {
  en: 'No articles found',
  es: 'No se encontraron artículos',
  de: 'Keine Artikel gefunden',
  fr: 'Aucun article trouvé',
};

const blogBase = lang === 'en' ? '/blog' : `/${lang}/blog`;
---

<div class="blog-search" data-posts={JSON.stringify(posts)} data-blog-base={blogBase} data-no-results={noResultsText[lang] || noResultsText.en}>
  <div class="blog-search__input-wrap">
    <svg class="blog-search__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="8"/>
      <path d="M21 21l-4.35-4.35"/>
    </svg>
    <input
      type="search"
      class="blog-search__input"
      placeholder={placeholders[lang] || placeholders.en}
      autocomplete="off"
      aria-label={placeholders[lang] || placeholders.en}
    />
  </div>
  <div class="blog-search__results" aria-live="polite"></div>
</div>

<style>
  .blog-search {
    max-width: 560px;
    margin: 0 auto;
    position: relative;
  }

  .blog-search__input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .blog-search__icon {
    position: absolute;
    left: 14px;
    color: var(--mc-text-muted, #5A6B52);
    pointer-events: none;
    flex-shrink: 0;
  }

  .blog-search__input {
    width: 100%;
    padding: .7rem 1rem .7rem 2.75rem;
    font-family: inherit;
    font-size: .95rem;
    color: var(--mc-text, #2D4A22);
    background: var(--mc-white, #fff);
    border: 1.5px solid var(--mc-border, #E2E8F0);
    border-radius: var(--radius-pill, 999px);
    outline: none;
    transition: border-color .2s, box-shadow .2s;
  }

  .blog-search__input::placeholder {
    color: var(--mc-text-muted, #5A6B52);
    opacity: .65;
  }

  .blog-search__input:focus {
    border-color: var(--mc-green-mid, #3D6B2E);
    box-shadow: 0 0 0 3px rgba(45, 74, 34, .12);
  }

  .blog-search__results {
    margin-top: .5rem;
    border-radius: var(--radius-md, 16px);
    overflow: hidden;
  }

  .blog-search__results:empty {
    display: none;
  }

  .blog-search__results :global(.blog-search__item) {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .6rem .85rem;
    text-decoration: none;
    color: var(--mc-text, #2D4A22);
    border-bottom: 1px solid var(--mc-border, #E2E8F0);
    transition: background .15s;
  }

  .blog-search__results :global(.blog-search__item:last-child) {
    border-bottom: none;
  }

  .blog-search__results :global(.blog-search__item:hover) {
    background: var(--mc-sand, #F5F0E8);
  }

  .blog-search__results :global(.blog-search__thumb) {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm, 8px);
    object-fit: cover;
    flex-shrink: 0;
  }

  .blog-search__results :global(.blog-search__info) {
    flex: 1;
    min-width: 0;
  }

  .blog-search__results :global(.blog-search__title) {
    font-size: .9rem;
    font-weight: 600;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .blog-search__results :global(.blog-search__desc) {
    font-size: .78rem;
    color: var(--mc-text-muted, #5A6B52);
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .blog-search__results :global(.blog-search__no-results) {
    padding: 1rem;
    text-align: center;
    font-size: .9rem;
    color: var(--mc-text-muted, #5A6B52);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const wrap = document.querySelector('.blog-search') as HTMLElement;
    if (!wrap) return;

    const input = wrap.querySelector('.blog-search__input') as HTMLInputElement;
    const resultsEl = wrap.querySelector('.blog-search__results') as HTMLElement;
    const posts = JSON.parse(wrap.dataset.posts || '[]');
    const blogBase = wrap.dataset.blogBase || '/blog';
    const noResultsMsg = wrap.dataset.noResults || 'No articles found';

    let timer: ReturnType<typeof setTimeout>;

    function search(query: string) {
      const q = query.trim().toLowerCase();
      resultsEl.innerHTML = '';

      if (!q) return;

      const matches = posts.filter((p: any) => {
        const haystack = [p.title, p.description, ...(p.tags || [])].join(' ').toLowerCase();
        return q.split(/\s+/).every((word: string) => haystack.includes(word));
      });

      if (matches.length === 0) {
        resultsEl.innerHTML = `<div class="blog-search__no-results">${noResultsMsg}</div>`;
        return;
      }

      const html = matches.map((p: any) => {
        const href = `${blogBase}/${p.slug}/`;
        const imgSrc = p.image.includes('?') ? p.image + '&w=96&h=96&fit=crop' : p.image + '?w=96&h=96&fit=crop';
        return `<a href="${href}" class="blog-search__item">
          <img src="${imgSrc}" alt="" class="blog-search__thumb" width="48" height="48" loading="lazy">
          <div class="blog-search__info">
            <div class="blog-search__title">${escapeHtml(p.title)}</div>
            <div class="blog-search__desc">${escapeHtml(p.description)}</div>
          </div>
        </a>`;
      }).join('');

      resultsEl.innerHTML = html;
    }

    function escapeHtml(str: string) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    input.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(() => search(input.value), 300);
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        input.value = '';
        resultsEl.innerHTML = '';
        input.blur();
      }
    });
  });
</script>
