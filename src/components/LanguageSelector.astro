---
import { getAlternatePath } from '../i18n/routes';
import type { Lang } from '../i18n/config';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

const allLangs: { code: Lang; label: string; hreflang: string; ariaLabel: string }[] = [
  { code: 'en', label: 'EN', hreflang: 'en', ariaLabel: 'Switch to English' },
  { code: 'es', label: 'ES', hreflang: 'es', ariaLabel: 'Cambiar a Español' },
  { code: 'de', label: 'DE', hreflang: 'de', ariaLabel: 'Auf Deutsch wechseln' },
  { code: 'fr', label: 'FR', hreflang: 'fr', ariaLabel: 'Passer au Français' },
];
---

<div class="lang-selector" aria-label="Language selector">
  <svg class="lang-selector__globe" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="10"/>
    <ellipse cx="12" cy="12" rx="4" ry="10"/>
    <line x1="2" y1="12" x2="22" y2="12"/>
    <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
  </svg>
  {allLangs.map((l, i) => (
    <>
      {i > 0 && <span class="lang-selector__divider" aria-hidden="true">|</span>}
      {l.code === lang ? (
        <span class="lang-selector__link lang-selector__link--active" aria-current="true">{l.label}</span>
      ) : (
        <a href={getAlternatePath(currentPath, l.code)} class="lang-selector__link" hreflang={l.hreflang} aria-label={l.ariaLabel}>{l.label}</a>
      )}
    </>
  ))}
</div>
