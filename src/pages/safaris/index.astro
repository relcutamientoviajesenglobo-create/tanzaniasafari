---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { touristAttraction, faqPage } from '../../i18n/schema';
import SafariTikTok from '../../components/SafariTikTok.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';

const galleryImages = [
  { src: 'https://images.unsplash.com/photo-1523805009345-7448845a9e53?w=600&h=400&fit=crop&auto=format', alt: 'Safari 4x4 vehicle on a game drive through the golden Serengeti savanna' },
  { src: 'https://images.unsplash.com/photo-1516426122078-c23e76319801?w=600&h=400&fit=crop&auto=format', alt: 'Vast Serengeti plains at sunrise with scattered acacia trees' },
  { src: 'https://images.unsplash.com/photo-1560440976-a8a309ea5837?w=600&h=400&fit=crop&auto=format', alt: 'Wildebeest herd crossing the Serengeti during the Great Migration' },
  { src: 'https://images.unsplash.com/photo-1546182990-dffeafbe841d?w=600&h=400&fit=crop&auto=format', alt: 'Lion resting on a kopje rock formation in the Serengeti' },
  { src: 'https://images.unsplash.com/photo-1557050543-4d5f4e07ef46?w=600&h=400&fit=crop&auto=format', alt: 'Elephant herd walking across the savanna at golden hour' },
  { src: 'https://images.unsplash.com/photo-1547970810-dc1eac37d174?w=600&h=400&fit=crop&auto=format', alt: 'Giraffe silhouette against a dramatic African sunset sky' },
];

const lang = 'en';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const faqItems = [
  { question: 'What types of safaris are available in Tanzania?', answer: 'We offer three main safari types: <strong>Classic Safari</strong> (traditional game drives in 4x4 vehicles), <strong>Photo Safari</strong> (specialized tours for photography enthusiasts) and <strong>Night Safari</strong> (nocturnal wildlife experiences). Each can be customized as day trips or multi-day expeditions. Visit our <a href="/prices/" style="color:#3D6B2E;font-weight:700">prices page</a> for package details.' },
  { question: 'How long should my safari be?', answer: 'We recommend a minimum of <strong>3 days</strong> to fully experience the Serengeti and Ngorongoro. A 5-7 day safari allows you to explore multiple parks at a relaxed pace. Day safaris are also available from Arusha for those with limited time. Our guides can help design the perfect itinerary for your schedule.' },
  { question: 'What is the difference between a classic and photo safari?', answer: 'A <strong>Classic Safari</strong> focuses on comprehensive game viewing with multiple stops and locations. A <strong><a href="/safaris/photo-safari/" style="color:#3D6B2E;font-weight:700">Photo Safari</a></strong> is designed specifically for photographers, with extended time at sighting locations, optimal positioning for light conditions, pop-top vehicles for unobstructed angles and guidance from experienced wildlife photographers.' },
  { question: 'Are safaris suitable for children?', answer: 'Absolutely! Tanzania safaris are a fantastic family experience. Children under 5 enter <strong>free</strong> on most safaris. We provide child-friendly vehicles, shorter driving routes for younger children and guides experienced with families. Children 5-11 receive discounted rates. See our <a href="/prices/" style="color:#3D6B2E;font-weight:700">prices page</a> for family packages.' },
  { question: 'What vehicles do you use for safaris?', answer: 'We use custom-built <strong>Toyota Land Cruisers</strong> and Land Rovers with pop-up roofs for 360-degree wildlife viewing. All vehicles have charging ports, cooler boxes for drinks, first aid kits and satellite communication. Maximum 6 passengers per vehicle ensures everyone has a window seat.' },
];

const schema = [
  touristAttraction({
    name: 'Safari Types in Tanzania — Classic, Photography & Night Safaris',
    description: 'Discover the best safari experiences in Tanzania. Classic game drives, photography tours and nocturnal wildlife adventures in the Serengeti and Ngorongoro.',
    url: 'https://tanzaniasafari.info/safaris/',
  }),
  faqPage(faqItems),
];
---

<BaseLayout
  title="Safari Types in Tanzania — Classic, Photography & Night Safaris"
  description="Discover the best safari experiences in Tanzania. Classic game drives in 4x4 vehicles, photography tours with expert guides and nocturnal wildlife adventures in the Serengeti."
  lang={lang}
  schema={schema}
  breadcrumbs={[{ label: 'Safaris' }]}
>
  <Header slot="header" lang={lang} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__acacia hero__acacia--tr" style="color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container">
      <div class="hero__inner">
        <div class="hero__text">
          <span class="chip chip--green">Serengeti &amp; Ngorongoro</span>
          <h1 class="hero__title">Safari experiences in Tanzania</h1>
          <p class="hero__desc">Choose your perfect safari adventure. From classic game drives to specialized photography tours and thrilling nocturnal expeditions, Tanzania delivers wildlife encounters unlike anywhere else.</p>
          <div class="hero__actions">
            <a href="/prices/" class="btn btn--primary btn--lg">See prices 2026</a>
            <a href="/contact/" class="btn btn--outline btn--lg">Plan your trip</a>
          </div>
        </div>
        <div class="hero__visual">
          <div class="hero__photo-frame">
            <div class="hero__deco hero__deco--tr"></div>
            <img
              src="https://images.unsplash.com/photo-1523805009345-7448845a9e53?w=800&h=640&fit=crop&auto=format"
              alt="Safari vehicle on a game drive through the golden Serengeti grasslands"
              width="800" height="640" loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SAFARI TYPES -->
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--amber">Choose Your Adventure</span>
        <h2>Our safari types</h2>
        <p>Every safari is tailored to deliver an extraordinary wildlife experience. Select the style that matches your interests and we handle the rest.</p>
      </div>
      <div class="card-grid card-grid--3 animate-on-scroll delay-1">
        <a href="/safaris/classic-safari/" class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1516426122078-c23e76319801?w=600&h=450&fit=crop&auto=format" alt="Serengeti landscape during a classic game drive safari" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Most Popular</span>
            <h3 class="photo-card__title">Classic Safari</h3>
            <p>The quintessential Tanzanian safari experience. Game drives in custom 4x4 vehicles through the Serengeti and Ngorongoro Crater with expert local guides. Spot the Big Five, witness the Great Migration and immerse yourself in the African wilderness.</p>
            <span class="photo-card__arrow"><svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 4 13 10 7 16"/></svg></span>
          </div>
        </a>
        <a href="/safaris/photo-safari/" class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1546182990-dffeafbe841d?w=600&h=450&fit=crop&auto=format" alt="Male lion in golden light, perfect for wildlife photography" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">For Photographers</span>
            <h3 class="photo-card__title">Photo Safari</h3>
            <p>Designed for photography enthusiasts. Extended time at sightings, vehicles positioned for optimal light, professional tips and guidance. Capture magazine-worthy images of Tanzania's wildlife in their natural habitat.</p>
            <span class="photo-card__arrow"><svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 4 13 10 7 16"/></svg></span>
          </div>
        </a>
        <a href="/safaris/night-safari/" class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1456926631375-92c8ce872def?w=600&h=450&fit=crop&auto=format" alt="Leopard in low light during a night safari expedition" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">After Dark</span>
            <h3 class="photo-card__title">Night Safari</h3>
            <p>Experience the African bush after sunset. Using specialized spotlights and night-vision equipment, discover nocturnal predators, bush babies, aardvarks and the haunting sounds of the savanna at night.</p>
            <span class="photo-card__arrow"><svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 4 13 10 7 16"/></svg></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="section section--green bg-green" style="position:relative;overflow:hidden">
    <div style="position:absolute;bottom:0;left:-30px;opacity:.08;pointer-events:none;color:#D4A017;transform:rotate(180deg)">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--amber">Every Safari Includes</span>
        <h2>What is included</h2>
        <p>All our safaris include essential services so you can focus on the experience.</p>
      </div>
      <div class="service-cards animate-on-scroll delay-1">
        <div class="service-card">
          <div class="service-card__icon">
            <svg viewBox="0 0 48 48" fill="currentColor"><path d="M40 8H8c-2.21 0-3.98 1.79-3.98 4L4 36c0 2.21 1.79 4 4 4h32c2.21 0 4-1.79 4-4V12c0-2.21-1.79-4-4-4zm-2 8L24 26 10 16v-4l14 10 14-10v4z"/></svg>
          </div>
          <h3 class="service-card__title">Hotel Pickup</h3>
          <p class="service-card__desc">Complimentary pickup and drop-off from your Arusha or Moshi hotel or the airport.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg viewBox="0 0 48 48" fill="currentColor"><path d="M24 4C12.95 4 4 12.95 4 24s8.95 20 20 20 20-8.95 20-20S35.05 4 24 4zm-2 30l-10-10 2.83-2.83L22 28.34l13.17-13.17L38 18 22 34z"/></svg>
          </div>
          <h3 class="service-card__title">Expert Guide</h3>
          <p class="service-card__desc">Certified English-speaking guide with years of experience in Tanzania's national parks.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg viewBox="0 0 48 48" fill="currentColor"><path d="M20 4H4v16h16V4zm-2 14H6V6h12v12zm18-14H20v16h16V4zm-2 14H22V6h12v12zM4 28v16h16V28H4zm14 14H6V30h12v12zm10-14h16v16H28V28zm14 14H30V30h12v12z"/></svg>
          </div>
          <h3 class="service-card__title">Park Fees</h3>
          <p class="service-card__desc">All national park entrance fees, conservation charges and crater descent fees included.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg viewBox="0 0 48 48" fill="currentColor"><path d="M16 6l2.29 2.29-4.88 4.88-2.83-2.83L16 6zM2 22v-4h6v4H2zm14-5c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9zm0 16c-3.86 0-7-3.14-7-7s3.14-7 7-7 7 3.14 7 7-3.14 7-7 7zm20-11h6v4h-6v-4zM32 6l5.42 4.34-2.83 2.83-4.88-4.88L32 6z"/></svg>
          </div>
          <h3 class="service-card__title">Meals & Drinks</h3>
          <p class="service-card__desc">Packed lunch, snacks and unlimited bottled water during game drives. Full board on multi-day trips.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PARKS WE VISIT -->
  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--green">Destinations</span>
        <h2>Parks and reserves we visit</h2>
        <p>Our safaris access Tanzania's most spectacular wildlife areas, from the iconic Serengeti to hidden gems known only to local guides.</p>
      </div>
      <div class="card-grid card-grid--2 animate-on-scroll delay-1">
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1516426122078-c23e76319801?w=600&h=450&fit=crop&auto=format" alt="Serengeti National Park vast savanna landscape" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">UNESCO World Heritage</span>
            <h3 class="photo-card__title">Serengeti National Park</h3>
            <p>The crown jewel of African safaris. Home to the Great Migration, over 3,000 lions and endless plains stretching to the horizon. The Serengeti ecosystem spans 30,000 square kilometers of pristine wilderness.</p>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1745885979468-44a855f8a5fa?w=600&h=450&fit=crop&auto=format" alt="Ngorongoro Crater aerial view with lush green floor" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Natural Wonder</span>
            <h3 class="photo-card__title">Ngorongoro Crater</h3>
            <p>The world's largest intact volcanic caldera and a natural amphitheater for wildlife. Home to approximately 25,000 animals including the rare black rhino, lions, flamingos and hippos in a 260 square kilometer crater floor.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--green">FAQ</span>
        <h2>Safari questions answered</h2>
        <p>Common questions about our Tanzania safari experiences and what to expect.</p>
      </div>
      <div class="faq-list animate-on-scroll delay-1">
        {faqItems.map(item => (
          <details>
            <summary>{item.question}</summary>
            <div class="faq-answer" set:html={item.answer} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <PhotoGallery images={galleryImages} title="Safari in Tanzania" />
  <SafariTikTok category="serengeti" lang="en" />

  <!-- CTA -->
  <section class="section section--green bg-green" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.1;pointer-events:none;color:#D4A017">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container" style="text-align:center">
      <div class="section__header animate-on-scroll">
        <h2>Ready to book your safari?</h2>
        <p>Choose your ideal safari type and let our expert team craft an unforgettable Tanzanian adventure.</p>
      </div>
      <div class="animate-on-scroll delay-1" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/prices/" class="btn btn--primary btn--lg">See prices 2026</a>
        <a href="/contact/" class="btn btn--outline btn--lg" style="border-color:white;color:white">Contact us</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</BaseLayout>
