---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { lodging, faqPage } from '../../../i18n/schema';

const title = 'Lodges de Safari en Tanzania — Alojamiento de Lujo en la Sabana';
const description = 'Descubre los mejores lodges de safari en Tanzania: alojamiento de lujo con vistas al Serengeti, Ngorongoro y Tarangire. Piscinas, restaurantes gourmet y servicio excepcional.';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const breadcrumbs = [
  { label: 'Hospedaje', href: '/hospedaje/' },
  { label: 'Lodges' },
];

const faqs = [
  { question: 'Que incluye la estancia en un lodge de safari?', answer: 'La mayoria de lodges incluyen pension completa (desayuno, almuerzo y cena), dos game drives diarios, transporte en 4x4, guia profesional y acceso a piscina e instalaciones.' },
  { question: 'Cual es la mejor epoca para hospedarse en un lodge?', answer: 'La temporada seca (junio-octubre) es ideal para avistamientos de fauna. La temporada verde (noviembre-mayo) ofrece paisajes exuberantes y tarifas mas accesibles.' },
  { question: 'Los lodges tienen WiFi y electricidad?', answer: 'La mayoria de lodges de lujo ofrecen WiFi en areas comunes y electricidad 24 horas. Algunos lodges eco-friendly usan energia solar con horarios de electricidad limitados.' },
];

const schema = [
  lodging('LodgingBusiness', {
    name: 'Lodges de Safari Tanzania',
    description,
    url: 'https://safaritanzania.info/hospedaje/lodges/',
  }),
  faqPage(faqs),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/hospedaje/lodges/"
  schema={schema}
  breadcrumbs={breadcrumbs}
>
  <Header slot="header" />
  <Footer slot="footer" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__acacia hero__acacia--tr" style="color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--green">Lujo</span>
        <h1 class="hero__title">Lodges de Safari en Tanzania</h1>
        <p class="hero__desc">Experimenta el lujo africano en lodges exclusivos con vistas impresionantes a la sabana, piscinas infinitas y servicio de clase mundial.</p>
        <div class="hero__actions">
          <a href="/precios/" class="btn btn--primary btn--lg">Ver Tarifas</a>
          <a href="/contacto/" class="btn btn--outline btn--lg">Reservar</a>
        </div>
        <div class="stats-row">
          <div class="stat">
            <strong>$350+</strong>
            <span style="font-size:.8rem;color:#2D4A22;opacity:.7">USD por noche</span>
          </div>
          <div class="stat">
            <strong>5 Estrellas</strong>
            <span style="font-size:.8rem;color:#2D4A22;opacity:.7">Servicio premium</span>
          </div>
          <div class="stat">
            <strong>24/7</strong>
            <span style="font-size:.8rem;color:#2D4A22;opacity:.7">Electricidad y WiFi</span>
          </div>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img
            src="https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=800&h=600&fit=crop&auto=format"
            alt="Lodge de lujo con piscina infinita en la sabana de Tanzania"
            width="600"
            height="480"
            loading="eager"
          >
        </div>
      </div>
    </div>
  </section>

  <!-- LODGES DESTACADOS -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="chip chip--amber">Destacados</span>
        <h2>Lodges Recomendados</h2>
        <p>Hemos seleccionado los mejores lodges en cada region para garantizar una experiencia inolvidable.</p>
      </div>

      <div class="card-grid card-grid--3">
        <div class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800&h=600&fit=crop&auto=format" alt="Lodge de lujo en el Serengeti" width="400" height="300" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Serengeti</span>
            <p class="photo-card__title">Serengeti Safari Lodge</p>
            <p style="font-size:.9rem;color:#5A6B52">Ubicado en las llanuras centrales del Serengeti con vista directa a la sabana. Suites con terraza privada, piscina infinita y restaurante con cocina de autor.</p>
          </div>
        </div>

        <div class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=800&h=600&fit=crop&auto=format" alt="Lodge en el borde del crater Ngorongoro" width="400" height="300" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Ngorongoro</span>
            <p class="photo-card__title">Ngorongoro Crater Lodge</p>
            <p style="font-size:.9rem;color:#5A6B52">En el borde del crater con vistas panoramicas. Chimeneas en cada habitacion, decoracion colonial africana y acceso exclusivo al crater al amanecer.</p>
          </div>
        </div>

        <div class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1571896349842-33c89424de2d?w=800&h=600&fit=crop&auto=format" alt="Lodge entre baobabs en Tarangire" width="400" height="300" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Tarangire</span>
            <p class="photo-card__title">Tarangire Treetop Lodge</p>
            <p style="font-size:.9rem;color:#5A6B52">Habitaciones elevadas entre baobabs antiguos. Una experiencia unica de dormir entre los arboles con vista a manadas de elefantes y jirafas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMODIDADES -->
  <section class="section section--gray">
    <div class="container">
      <div class="section__header">
        <h2>Comodidades de los Lodges</h2>
        <p>Todos nuestros lodges asociados ofrecen estandares de lujo y confort excepcionales.</p>
      </div>
      <div class="service-cards" style="grid-template-columns: repeat(4, 1fr)">
        <div class="service-card">
          <p class="service-card__title">Habitaciones Amplias</p>
          <p class="service-card__desc">Suites con balcon o terraza privada con vistas a la sabana y bano completo.</p>
        </div>
        <div class="service-card">
          <p class="service-card__title">Gastronomia</p>
          <p class="service-card__desc">Restaurantes con chefs internacionales, cocina fusion africana y opciones dieteticas.</p>
        </div>
        <div class="service-card">
          <p class="service-card__title">Piscina</p>
          <p class="service-card__desc">Piscinas infinitas con vistas a la naturaleza, ideales para relajarse entre safaris.</p>
        </div>
        <div class="service-card">
          <p class="service-card__title">Spa y Bienestar</p>
          <p class="service-card__desc">Masajes y tratamientos con productos naturales africanos en un entorno unico.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width:800px">
      <div class="section__header">
        <h2>Preguntas Frecuentes</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">{faq.question}</summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--green">
    <div class="container" style="text-align:center">
      <h2 style="color:white;margin-bottom:.75rem">Reserva tu Lodge de Safari</h2>
      <p style="color:rgba(255,255,255,.85);margin-bottom:1.5rem;max-width:500px;margin-left:auto;margin-right:auto">Nuestro equipo te ayuda a encontrar el lodge perfecto para tu aventura africana.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/precios/" class="btn btn--amber btn--lg">Ver Precios</a>
        <a href="/contacto/" class="btn btn--outline-white btn--lg">Contactar</a>
      </div>
    </div>
  </section>
</BaseLayout>
