---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';
import BlogSearch from '../../../components/blog/BlogSearch.astro';
import SafariTikTok from '../../../components/SafariTikTok.astro';
import { webPage } from '../../../i18n/schema';

const lang = 'de';
const title = 'Blog Tanzania Safari — Reiseführer, Tipps & Afrikanische Kultur';
const description = 'Artikel über Safaris in Tansania: Reiseführer, Fotografietipps, Masai-Kultur, beste Nationalparks und alles, was Sie für Ihr afrikanisches Abenteuer brauchen.';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const breadcrumbs = [
  { label: 'Blog' },
];

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.slug.startsWith('de-'))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const searchPosts = posts.map(post => ({
  title: post.data.title,
  description: post.data.description,
  slug: post.slug.replace(/^(en|es|de|fr)-/, ''),
  image: post.data.image,
  category: post.data.category,
  tags: post.data.tags,
}));

const silos = [
  { slug: 'safari-tansania', label: 'Tansania-Safaris', href: '/de/blog/safari-tansania/' },
  { slug: 'abenteuer-aktivitaeten', label: 'Abenteuer & Aktivitäten', href: '/de/blog/abenteuer-aktivitaeten/' },
  { slug: 'lodges-camps', label: 'Lodges & Camps', href: '/de/blog/lodges-camps/' },
  { slug: 'reisefuehrer', label: 'Reiseführer', href: '/de/blog/reisefuehrer/' },
  { slug: 'masai-kultur', label: 'Masai-Kultur', href: '/de/blog/masai-kultur/' },
];

const schema = [
  webPage({
    name: title,
    description,
    url: 'https://tanzaniasafari.info/de/blog/',
  }),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/de/blog/"
  schema={schema}
  breadcrumbs={breadcrumbs}
  lang={lang}
>
  <Header slot="header" lang={lang} />
  <Footer slot="footer" lang={lang} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__acacia hero__acacia--tr" style="color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--green">Blog</span>
        <h1 class="hero__title">Blog Tanzania Safari</h1>
        <p class="hero__desc">Reiseführer, Safari-Tipps, Wildtierfotografie, Masai-Kultur und alles, was Sie für Ihr Abenteuer in Afrika wissen müssen.</p>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img
            src="https://images.unsplash.com/photo-1516426122078-c23e76319801?w=800&h=600&fit=crop&auto=format"
            alt="Leopard ruhend auf einem Ast in der Serengeti"
            width="600"
            height="480"
            loading="eager"
          >
        </div>
      </div>
    </div>
  </section>

  <!-- KATEGORIEN / SILOS -->
  <section class="section section--gray">
    <div class="container">
      <div class="section__header">
        <h2>Nach Thema durchstöbern</h2>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center">
        {silos.map(silo => (
          <a href={silo.href} class="btn btn--outline btn--sm">{silo.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- SUCHE -->
  <section style="padding:0 0 2rem">
    <div class="container">
      <BlogSearch posts={searchPosts} lang={lang} />
    </div>
  </section>

  <!-- ALLE ARTIKEL -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Alle Artikel</h2>
        <p>{posts.length} {posts.length === 1 ? 'Artikel' : 'Artikel'} in {silos.length} Kategorien</p>
      </div>

      {posts.length > 0 ? (
        <div class="card-grid card-grid--3">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug.replace('de-', '')}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              author={post.data.author}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              category={post.data.category}
              lang={lang}
            />
          ))}
        </div>
      ) : (
        <div style="text-align:center;padding:3rem 0">
          <p style="font-size:1.1rem;color:#5A6B52">Wir bereiten herausragende Inhalte vor. Kommen Sie bald wieder, um unsere Artikel über Tansania-Safaris zu lesen.</p>
          <a href="/de/kontakt/" class="btn btn--primary" style="margin-top:1.5rem">Kontakt aufnehmen</a>
        </div>
      )}
    </div>
  </section>

  <!-- TIKTOK -->
  <SafariTikTok category="general" lang={lang} />

  <!-- CTA -->
  <section class="section section--green">
    <div class="container" style="text-align:center">
      <h2 style="color:white;margin-bottom:.75rem">Planen Sie Ihre Safari</h2>
      <p style="color:rgba(255,255,255,.85);margin-bottom:1.5rem;max-width:500px;margin-left:auto;margin-right:auto">Verwandeln Sie das Gelesene in ein echtes Abenteuer. Kontaktieren Sie uns für Ihre perfekte Tansania-Safari.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/de/preise/" class="btn btn--amber btn--lg">Preise 2026 ansehen</a>
        <a href="/de/kontakt/" class="btn btn--outline-white btn--lg">Kontakt</a>
      </div>
    </div>
  </section>
</BaseLayout>
