---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import BlogCard from '../../../../components/blog/BlogCard.astro';
import SafariTikTok from '../../../../components/SafariTikTok.astro';
import { getCollection } from 'astro:content';
import { webPage } from '../../../../i18n/schema';

const lang = 'de';
const title = 'Masai-Kultur — Traditionen & Erbe in Tansania';
const description = 'Tauchen Sie ein in die faszinierende Welt der Masai: Traditionen, Zeremonien, Lebensweise und kulturelle Erlebnisse in Tansania und Kenia.';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.slug.startsWith('de-') && (post.data.silo === 'cultura-masai' || post.data.silo === 'masai-culture' || post.data.silo === 'masai-kultur'))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const breadcrumbs = [
  { label: 'Blog', href: '/de/blog/' },
  { label: 'Masai-Kultur' },
];

const schema = [
  webPage({
    name: title,
    description,
    url: 'https://tanzaniasafari.info/de/blog/masai-kultur/',
  }),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/de/blog/masai-kultur/"
  schema={schema}
  breadcrumbs={breadcrumbs}
  lang={lang}
>
  <Header slot="header" lang={lang} />
  <Footer slot="footer" lang={lang} />

  <section class="hero" style="padding-bottom:2rem">
    <div class="container">
      <div style="text-align:center;max-width:700px;margin:0 auto">
        <span class="chip chip--green">Blog-Kategorie</span>
        <h1 style="margin-top:.75rem">Masai-Kultur</h1>
        <p>Entdecken Sie das reiche kulturelle Erbe der Masai: ihre Traditionen, Zeremonien, Schmuck, Gesang und wie sie seit Jahrhunderten im Einklang mit der Wildnis leben.</p>
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      {posts.length > 0 ? (
        <>
          <p style="text-align:center;margin-bottom:2.5rem;color:var(--mc-text-muted)">{posts.length} Artikel veröffentlicht</p>
          <div class="card-grid card-grid--3" style="grid-template-columns:repeat(auto-fit,minmax(300px,1fr))">
            {posts.map(post => (
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                slug={post.slug.replace('de-', '')}
                image={post.data.image}
                imageAlt={post.data.imageAlt}
                author={post.data.author}
                publishDate={post.data.publishDate}
                readingTime={post.data.readingTime}
                category={post.data.category}
                lang={lang}
              />
            ))}
          </div>
        </>
      ) : (
        <div style="text-align:center;padding:4rem 0">
          <span style="font-size:3rem;display:block;margin-bottom:1rem">🦁</span>
          <h2 style="font-size:1.5rem;margin-bottom:.75rem">Artikel kommen bald</h2>
          <p style="max-width:400px;margin:0 auto">Wir bereiten ausführliche Artikel vor. Schauen Sie bald wieder vorbei oder <a href="/de/blog/" style="color:#3D6B2E;font-weight:700">alle Artikel durchstöbern</a>.</p>
        </div>
      )}
    </div>
  </section>

  <!-- TIKTOK -->
  <SafariTikTok category="culture" lang={lang} />

  <section class="section section--green">
    <div class="container" style="text-align:center">
      <h2 style="color:white;margin-bottom:.75rem">Bereit für Ihre Tansania-Safari?</h2>
      <p style="color:rgba(255,255,255,.85);margin-bottom:1.5rem;max-width:520px;margin-left:auto;margin-right:auto">Erleben Sie die Masai-Kultur hautnah und entdecken Sie die Traditionen dieses faszinierenden Volkes.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/de/preise/" class="btn btn--primary btn--lg">Preise 2026 ansehen</a>
        <a href="/de/kontakt/" class="btn btn--outline-white btn--lg" style="border-color:white;color:white">Kontakt</a>
      </div>
    </div>
  </section>
</BaseLayout>
