---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { webPage } from '../../../i18n/schema';

const lang = 'de';
const title = 'Datenschutzerklärung — Safari Tanzania';
const description = 'Datenschutzerklärung von Safari Tanzania. Erfahren Sie, wie wir Ihre personenbezogenen Daten gemäß DSGVO erfassen, verwenden und schützen.';

const breadcrumbs = [
  { label: 'Datenschutzerklärung' },
];

const schema = [
  webPage({
    name: title,
    description,
    url: 'https://safaritanzania.info/de/datenschutz/',
  }),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/de/datenschutz/"
  schema={schema}
  breadcrumbs={breadcrumbs}
  lang={lang}
>
  <Header slot="header" lang={lang} />
  <Footer slot="footer" lang={lang} />

  <section class="section">
    <div class="container" style="max-width:800px">
      <h1 style="margin-bottom:2rem">Datenschutzerklärung</h1>
      <p style="font-size:.85rem;color:#5A6B52;margin-bottom:2rem"><strong>Letzte Aktualisierung:</strong> 14. März 2026</p>

      <div style="display:flex;flex-direction:column;gap:2rem">
        <div>
          <h2 style="font-size:1.3rem;margin-bottom:.75rem">1. Verantwortlicher</h2>
          <p>Verantwortlicher im Sinne der Datenschutz-Grundverordnung (DSGVO) ist Safari Tanzania, mit Sitz in Sokoine Road, Arusha, Tansania. Sie erreichen uns unter <a href="mailto:info@safaritanzania.info" style="color:#3D6B2E;font-weight:700">info@safaritanzania.info</a> oder telefonisch unter <a href="tel:+255753000000" style="color:#3D6B2E;font-weight:700">+255 753 000 000</a>.</p>
        </div>

        <div>
          <h2 style="font-size:1.3rem;margin-bottom:.75rem">2. Erhobene Daten</h2>
          <p>Wir erheben folgende personenbezogene Daten, wenn Sie uns kontaktieren oder eine Buchung vornehmen:</p>
          <ul style="margin-top:.75rem;padding-left:1.5rem;list-style:disc;display:flex;flex-direction:column;gap:.4rem;color:#5A6B52">
            <li>Vollständiger Name</li>
            <li>E-Mail-Adresse</li>
            <li>Telefonnummer</li>
            <li>Staatsangehörigkeit und Reisepassdaten (für Visa- und Parkeintrittsverfahren)</li>
            <li>Reisepräferenzen und Ernährungsanforderungen</li>
            <li>Zahlungsinformationen (verarbeitet über sichere Drittanbieter-Zahlungsgateways)</li>
          </ul>
        </div>

        <div>
          <h2 style="font-size:1.3rem;margin-bottom:.75rem">3. Zwecke der Datenverarbeitung</h2>
          <p>Wir verwenden Ihre Daten für folgende Zwecke:</p>
          <ul style="margin-top:.75rem;padding-left:1.5rem;list-style:disc;display:flex;flex-direction:column;gap:.4rem;color:#5A6B52">
            <li>Verwaltung und Bestätigung von Safari-Buchungen</li>
            <li>Kommunikation bezüglich Ihrer Reise (Reiseprogramm, Änderungen, Updates)</li>
            <li>Zahlungsabwicklung und Rechnungsstellung</li>
            <li>Erfüllung gesetzlicher Anforderungen der tansanischen Nationalparks und Behörden</li>
            <li>Versand von Werbeinformationen (ausschließlich mit Ihrer vorherigen Einwilligung)</li>
          </ul>
        </div>

        <div>
          <h2 style="font-size:1.3rem;margin-bottom:.75rem">4. Rechtsgrundlage der Verarbeitung</h2>
          <p>Die Verarbeitung Ihrer personenbezogenen Daten erfolgt auf folgenden Rechtsgrundlagen gemäß Art. 6 DSGVO:</p>
          <ul style="margin-top:.75rem;padding-left:1.5rem;list-style:disc;display:flex;flex-direction:column;gap:.4rem;color:#5A6B52">
            <li><strong>Art. 6 Abs. 1 lit. b DSGVO</strong> — Vertragserfüllung (Buchungsabwicklung)</li>
            <li><strong>Art. 6 Abs. 1 lit. c DSGVO</strong> — Erfüllung rechtlicher Verpflichtungen</li>
            <li><strong>Art. 6 Abs. 1 lit. a DSGVO</strong> — Einwilligung (für Marketingkommunikation)</li>
            <li><strong>Art. 6 Abs. 1 lit. f DSGVO</strong> — Berechtigte Interessen (Verbesserung unserer Dienstleistungen)</li>
          </ul>
        </div>

        <div>
          <h2 style="font-size:1.3rem;margin-bottom:.75rem">5. Weitergabe von Daten</h2>
          <p>Wir geben Ihre Daten ausschließlich weiter an:</p>
          <ul style="margin-top:.75rem;padding-left:1.5rem;list-style:disc;display:flex;flex-direction:column;gap:.4rem;color:#5A6B52">
            <li>Tansanische Nationalparkverwaltungen (für den Parkeintritt erforderlich)</li>
            <li>Unterkunftsanbieter (Lodges und Camps)</li>
            <li>Sichere Zahlungsdienstleister</li>
            <li>Staatliche Behörden, wenn gesetzlich vorgeschrieben</li>
          </ul>
          <p style="margin-top:.75rem">Wir verkaufen Ihre Daten nicht an Dritte und geben sie nicht zu Werbezwecken weiter.</p>
        </div>

        <div>
          <h2 style="font-size:1.3rem;margin-bottom:.75rem">6. Datensicherheit</h2>
          <p>Wir setzen geeignete technische und organisatorische Maßnahmen ein, um Ihre personenbezogenen Daten vor unbefugtem Zugriff, Verlust oder Veränderung zu schützen. Zahlungen werden über sichere Gateways mit SSL-Verschlüsselung verarbeitet.</p>
        </div>

        <div>
          <h2 style="font-size:1.3rem;margin-bottom:.75rem">7. Speicherdauer</h2>
          <p>Wir speichern Ihre personenbezogenen Daten nur so lange, wie es für die Erfüllung der oben genannten Zwecke erforderlich ist oder gesetzliche Aufbewahrungsfristen es verlangen. Buchungsdaten werden in der Regel für 7 Jahre gespeichert (steuerliche Aufbewahrungspflicht).</p>
        </div>

        <div>
          <h2 style="font-size:1.3rem;margin-bottom:.75rem">8. Ihre Rechte</h2>
          <p>Gemäß DSGVO haben Sie folgende Rechte:</p>
          <ul style="margin-top:.75rem;padding-left:1.5rem;list-style:disc;display:flex;flex-direction:column;gap:.4rem;color:#5A6B52">
            <li><strong>Auskunftsrecht</strong> (Art. 15 DSGVO) — Einsicht in Ihre gespeicherten Daten</li>
            <li><strong>Berichtigungsrecht</strong> (Art. 16 DSGVO) — Korrektur unrichtiger Daten</li>
            <li><strong>Recht auf Löschung</strong> (Art. 17 DSGVO) — Löschung Ihrer Daten</li>
            <li><strong>Recht auf Einschränkung</strong> (Art. 18 DSGVO) — Einschränkung der Verarbeitung</li>
            <li><strong>Widerspruchsrecht</strong> (Art. 21 DSGVO) — Widerspruch gegen die Verarbeitung</li>
            <li><strong>Recht auf Datenübertragbarkeit</strong> (Art. 20 DSGVO)</li>
            <li><strong>Widerrufsrecht</strong> — Widerruf einer erteilten Einwilligung jederzeit</li>
          </ul>
          <p style="margin-top:.75rem">Zur Ausübung dieser Rechte wenden Sie sich bitte an: <a href="mailto:info@safaritanzania.info" style="color:#3D6B2E;font-weight:700">info@safaritanzania.info</a>.</p>
          <p style="margin-top:.75rem">Sie haben außerdem das Recht, sich bei einer Datenschutzaufsichtsbehörde zu beschweren, wenn Sie der Ansicht sind, dass die Verarbeitung Ihrer Daten gegen die DSGVO verstößt.</p>
        </div>

        <div>
          <h2 style="font-size:1.3rem;margin-bottom:.75rem">9. Cookies</h2>
          <p>Diese Website verwendet ausschließlich technisch notwendige Cookies für ihren ordnungsgemäßen Betrieb. Wir verwenden keine Tracking- oder Werbe-Cookies. Analyse-Cookies dienen ausschließlich der Verbesserung der Nutzererfahrung und können in den Einstellungen Ihres Browsers deaktiviert werden.</p>
        </div>

        <div>
          <h2 style="font-size:1.3rem;margin-bottom:.75rem">10. Änderungen dieser Erklärung</h2>
          <p>Wir behalten uns das Recht vor, diese Datenschutzerklärung zu aktualisieren. Änderungen werden auf dieser Seite mit dem entsprechenden Aktualisierungsdatum veröffentlicht. Bei wesentlichen Änderungen werden registrierte Nutzer per E-Mail informiert.</p>
        </div>

        <div>
          <h2 style="font-size:1.3rem;margin-bottom:.75rem">11. Kontakt</h2>
          <p>Bei Fragen zum Datenschutz wenden Sie sich bitte an:<br>
          Safari Tanzania, Sokoine Road, Arusha, Tansania<br>
          E-Mail: <a href="mailto:info@safaritanzania.info" style="color:#3D6B2E;font-weight:700">info@safaritanzania.info</a><br>
          Telefon: <a href="tel:+255753000000" style="color:#3D6B2E;font-weight:700">+255 753 000 000</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
