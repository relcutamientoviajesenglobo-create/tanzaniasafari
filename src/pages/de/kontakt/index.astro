---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import SafariTikTok from '../../../components/SafariTikTok.astro';

const lang = 'de';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'TouristInformationCenter',
  name: 'Safari Tanzania — Buchungen & Anfragen',
  description: 'Kontaktieren Sie Safari Tanzania für individuelle Reiseplanungen, Safari-Buchungen und alle Fragen rund um Ihren Tansania-Urlaub.',
  url: 'https://safaritanzania.info/de/kontakt/',
  telephone: '+255753000000',
  email: 'info@safaritanzania.info',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Sokoine Road',
    addressLocality: 'Arusha',
    addressRegion: 'Arusha Region',
    addressCountry: 'TZ',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: -3.3869,
    longitude: 36.6830,
  },
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
    opens: '06:00',
    closes: '18:00',
  }],
  image: 'https://safaritanzania.info/media/safari-tanzania-serengeti-panoramica.webp',
};
---

<BaseLayout
  title="Kontakt Safari Tanzania — Buchungen & Anfragen"
  description="Kontaktieren Sie unser erfahrenes Safari-Team in Arusha, Tansania. Wir helfen Ihnen bei der Planung Ihrer individuellen Safari-Reise 2026. WhatsApp, E-Mail oder Telefon — wir sind für Sie da."
  lang={lang}
  schema={schema}
  breadcrumbs={[{ label: 'Kontakt' }]}
>
  <Header slot="header" lang={lang} />

  <!-- HERO -->
  <section class="hero" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:-20px;right:-40px;opacity:.08;pointer-events:none;color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container">
      <div class="hero__inner">
        <div class="hero__text">
          <span class="chip chip--green">Wir sind für Sie da</span>
          <h1 class="hero__title">Kontaktieren Sie uns</h1>
          <p class="hero__desc">Unser erfahrenes Safari-Team in Arusha steht Ihnen jederzeit zur Verfügung. Ob Sie eine maßgeschneiderte Safari planen, Fragen zu unseren Paketen haben oder ein Angebot wünschen — wir antworten innerhalb von 24 Stunden.</p>
          <div class="hero__actions">
            <a href="https://wa.me/255753000000?text=Hallo%2C%20ich%20m%C3%B6chte%20eine%20Safari%20in%20Tansania%20buchen" class="btn btn--primary btn--lg" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" style="margin-right:.5rem" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              WhatsApp schreiben
            </a>
            <a href="tel:+255753000000" class="btn btn--outline btn--lg">
              Jetzt anrufen
            </a>
          </div>
        </div>
        <div class="hero__visual">
          <div class="hero__photo-frame">
            <div class="hero__deco hero__deco--tr"></div>
            <div class="hero__deco hero__deco--bl"></div>
            <img
              src="https://images.unsplash.com/photo-1516426122078-c23e76319801?w=800&h=640&fit=crop&auto=format"
              alt="Serengeti Savanne bei Sonnenuntergang — Safari Tanzania Kontakt"
              width="800" height="640" loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- KONTAKTMETHODEN -->
  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--amber">Erreichen Sie uns</span>
        <h2>Unsere Kontaktwege</h2>
        <p>Wählen Sie die für Sie bequemste Art, mit unserem Team in Verbindung zu treten. Wir sprechen Deutsch, Englisch und Swahili.</p>
      </div>
      <div class="card-grid card-grid--4 animate-on-scroll delay-1">
        <!-- WhatsApp -->
        <a href="https://wa.me/255753000000?text=Hallo%2C%20ich%20m%C3%B6chte%20eine%20Safari%20in%20Tansania%20buchen" class="photo-card" target="_blank" rel="noopener noreferrer" style="text-decoration:none">
          <div class="photo-card__body" style="text-align:center">
            <div style="width:56px;height:56px;border-radius:50%;background:#25D366;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="white" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </div>
            <h3 class="photo-card__title" style="font-size:1.1rem">WhatsApp</h3>
            <p style="font-size:.9rem;color:var(--mc-text-muted)">Sofortige Antwort. Ideal für schnelle Fragen und Angebote.</p>
            <strong style="color:#25D366">+255 753 000 000</strong>
          </div>
        </a>
        <!-- E-Mail -->
        <a href="mailto:info@safaritanzania.info" class="photo-card" style="text-decoration:none">
          <div class="photo-card__body" style="text-align:center">
            <div style="width:56px;height:56px;border-radius:50%;background:var(--mc-green);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="white" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3 class="photo-card__title" style="font-size:1.1rem">E-Mail</h3>
            <p style="font-size:.9rem;color:var(--mc-text-muted)">Ausführliche Anfragen. Wir antworten innerhalb von 24 Stunden.</p>
            <strong style="color:var(--mc-green)">info@safaritanzania.info</strong>
          </div>
        </a>
        <!-- Telefon -->
        <a href="tel:+255753000000" class="photo-card" style="text-decoration:none">
          <div class="photo-card__body" style="text-align:center">
            <div style="width:56px;height:56px;border-radius:50%;background:var(--mc-amber,#D4A017);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="white" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
            </div>
            <h3 class="photo-card__title" style="font-size:1.1rem">Telefon</h3>
            <p style="font-size:.9rem;color:var(--mc-text-muted)">Mo.–So. 06:00–18:00 Uhr (Ostafrika-Zeit)</p>
            <strong style="color:var(--mc-amber,#D4A017)">+255 753 000 000</strong>
          </div>
        </a>
        <!-- Büro -->
        <div class="photo-card">
          <div class="photo-card__body" style="text-align:center">
            <div style="width:56px;height:56px;border-radius:50%;background:#6B4C2A;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="white" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="photo-card__title" style="font-size:1.1rem">Büro Arusha</h3>
            <p style="font-size:.9rem;color:var(--mc-text-muted)">Sokoine Road, Arusha</p>
            <strong style="color:#6B4C2A">Tansania, Ostafrika</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- KONTAKTFORMULAR -->
  <section class="section" style="position:relative;overflow:hidden">
    <div style="position:absolute;bottom:-30px;left:-40px;opacity:.05;pointer-events:none;color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start" class="contact-grid">
        <div class="animate-on-scroll">
          <span class="chip chip--green">Kostenlose Beratung</span>
          <h2 style="margin-top:.75rem">Senden Sie uns Ihre Anfrage</h2>
          <p style="color:var(--mc-text-muted);margin-bottom:2rem">Füllen Sie das Formular aus und wir melden uns innerhalb von 24 Stunden mit einem personalisierten Angebot. Keine Verpflichtung, keine versteckten Kosten.</p>
          <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.75rem">
            <li style="display:flex;align-items:center;gap:.75rem">
              <span style="width:32px;height:32px;border-radius:50%;background:var(--mc-green);color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;flex-shrink:0">✓</span>
              <span>Kostenloser individueller Reiseplan</span>
            </li>
            <li style="display:flex;align-items:center;gap:.75rem">
              <span style="width:32px;height:32px;border-radius:50%;background:var(--mc-green);color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;flex-shrink:0">✓</span>
              <span>Antwort innerhalb von 24 Stunden</span>
            </li>
            <li style="display:flex;align-items:center;gap:.75rem">
              <span style="width:32px;height:32px;border-radius:50%;background:var(--mc-green);color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;flex-shrink:0">✓</span>
              <span>Deutschsprachige Betreuung</span>
            </li>
            <li style="display:flex;align-items:center;gap:.75rem">
              <span style="width:32px;height:32px;border-radius:50%;background:var(--mc-green);color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;flex-shrink:0">✓</span>
              <span>Keine Anzahlung bei Erstanfrage</span>
            </li>
          </ul>
        </div>
        <div class="animate-on-scroll delay-1">
          <form
            action="https://formsubmit.co/info@safaritanzania.info"
            method="POST"
            class="contact-form"
            style="background:var(--mc-sand,#F5F0E8);border-radius:var(--radius-lg,20px);padding:2rem;border:1px solid var(--mc-border,#E2E8F0)"
          >
            <input type="hidden" name="_subject" value="Neue Safari-Anfrage von der Website (DE)" />
            <input type="hidden" name="_next" value="https://safaritanzania.info/de/kontakt/" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
              <div class="form-group">
                <label for="name" style="display:block;font-weight:600;margin-bottom:.4rem;font-size:.9rem">Vor- und Nachname *</label>
                <input type="text" id="name" name="name" required placeholder="Max Mustermann" style="width:100%;padding:.7rem 1rem;border:1px solid var(--mc-border,#E2E8F0);border-radius:8px;font-size:1rem;background:white;box-sizing:border-box" />
              </div>
              <div class="form-group">
                <label for="email" style="display:block;font-weight:600;margin-bottom:.4rem;font-size:.9rem">E-Mail-Adresse *</label>
                <input type="email" id="email" name="email" required placeholder="max@beispiel.de" style="width:100%;padding:.7rem 1rem;border:1px solid var(--mc-border,#E2E8F0);border-radius:8px;font-size:1rem;background:white;box-sizing:border-box" />
              </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
              <div class="form-group">
                <label for="phone" style="display:block;font-weight:600;margin-bottom:.4rem;font-size:.9rem">Telefon / WhatsApp</label>
                <input type="tel" id="phone" name="phone" placeholder="+49 123 456789" style="width:100%;padding:.7rem 1rem;border:1px solid var(--mc-border,#E2E8F0);border-radius:8px;font-size:1rem;background:white;box-sizing:border-box" />
              </div>
              <div class="form-group">
                <label for="reisende" style="display:block;font-weight:600;margin-bottom:.4rem;font-size:.9rem">Anzahl Reisende</label>
                <select id="reisende" name="reisende" style="width:100%;padding:.7rem 1rem;border:1px solid var(--mc-border,#E2E8F0);border-radius:8px;font-size:1rem;background:white;box-sizing:border-box">
                  <option value="">Bitte wählen</option>
                  <option value="1">1 Person</option>
                  <option value="2">2 Personen</option>
                  <option value="3-4">3–4 Personen</option>
                  <option value="5-6">5–6 Personen</option>
                  <option value="7+">7+ Personen</option>
                </select>
              </div>
            </div>

            <div class="form-group" style="margin-bottom:1rem">
              <label for="reisedaten" style="display:block;font-weight:600;margin-bottom:.4rem;font-size:.9rem">Gewünschte Reisedaten</label>
              <input type="text" id="reisedaten" name="reisedaten" placeholder="z.B. Juli 2026, 2 Wochen" style="width:100%;padding:.7rem 1rem;border:1px solid var(--mc-border,#E2E8F0);border-radius:8px;font-size:1rem;background:white;box-sizing:border-box" />
            </div>

            <div class="form-group" style="margin-bottom:1.5rem">
              <label for="nachricht" style="display:block;font-weight:600;margin-bottom:.4rem;font-size:.9rem">Ihre Nachricht *</label>
              <textarea id="nachricht" name="nachricht" required rows="5" placeholder="Beschreiben Sie Ihre Traumsafari. Welche Parks möchten Sie besuchen? Haben Sie besondere Wünsche? Interessieren Sie sich für ein bestimmtes Paket?" style="width:100%;padding:.7rem 1rem;border:1px solid var(--mc-border,#E2E8F0);border-radius:8px;font-size:1rem;background:white;resize:vertical;box-sizing:border-box"></textarea>
            </div>

            <button type="submit" class="btn btn--primary btn--lg" style="width:100%">
              Anfrage absenden
            </button>
            <p style="font-size:.8rem;color:var(--mc-text-muted);text-align:center;margin-top:.75rem">Mit dem Absenden stimmen Sie unserer <a href="/de/datenschutz/" style="color:var(--mc-green)">Datenschutzerklärung</a> zu.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- TIKTOK -->
  <SafariTikTok category="general" lang="de" />

  <!-- CTA -->
  <section class="section section--green bg-green" style="text-align:center;position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.1;pointer-events:none;color:#D4A017">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Bereit für Ihr Safari-Abenteuer?</h2>
        <p>Sehen Sie sich unsere Pakete an oder lesen Sie, wie Sie nach Tansania reisen.</p>
      </div>
      <div class="animate-on-scroll delay-1" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/de/preise/" class="btn btn--primary btn--lg">Preise & Pakete</a>
        <a href="/de/anreise/" class="btn btn--outline btn--lg" style="border-color:white;color:white">Anreise nach Tansania</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</BaseLayout>

<style>
@media (max-width: 768px) {
  .contact-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
  .card-grid--4 { grid-template-columns: repeat(2, 1fr) !important; }
}
@media (max-width: 480px) {
  .card-grid--4 { grid-template-columns: 1fr !important; }
}
</style>
