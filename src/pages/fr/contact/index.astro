---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { localBusiness } from '../../../i18n/schema';
import SafariTikTok from '../../../components/SafariTikTok.astro';

const lang = 'fr';
const title = 'Contact Tanzania Safari — Réservations & Renseignements';
const description = 'Contactez Tanzania Safari pour réserver votre safari, demander un devis personnalisé ou poser vos questions. Réponse sous 24h par WhatsApp, email ou téléphone.';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const breadcrumbs = [
  { label: 'Contact' },
];

const schema = [
  localBusiness({
    name: 'Tanzania Safari',
    description,
    url: 'https://tanzaniasafari.info/fr/contact/',
    '@type': 'TouristInformationCenter',
  }),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/fr/contact/"
  schema={schema}
  breadcrumbs={breadcrumbs}
  lang={lang}
>
  <Header slot="header" lang={lang} />
  <Footer slot="footer" lang={lang} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__acacia hero__acacia--tr" style="color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--green">Contact</span>
        <h1 class="hero__title">Contactez-nous</h1>
        <p class="hero__desc">Notre équipe est prête à vous aider à planifier le safari de vos rêves en Tanzanie. Nous répondons en moins de 24 heures, souvent bien avant.</p>
        <div class="hero__actions">
          <a href="https://wa.me/255753000000?text=Bonjour,%20je%20souhaite%20des%20informations%20sur%20un%20safari%20en%20Tanzanie" class="btn btn--primary btn--lg" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.855L.057 23.928l6.204-1.457A11.93 11.93 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0"/></svg>
            WhatsApp
          </a>
          <a href="tel:+255753000000" class="btn btn--outline btn--lg">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.62 10.79z"/></svg>
            Appeler
          </a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img
            src="https://images.unsplash.com/photo-1611348586804-61bf6c080437?w=800&h=600&fit=crop&auto=format"
            alt="Équipe de guides safari à Arusha, Tanzanie"
            width="600"
            height="480"
            loading="eager"
          >
        </div>
      </div>
    </div>
  </section>

  <!-- MOYENS DE CONTACT -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Nos Coordonnées</h2>
        <p>Choisissez le canal qui vous convient le mieux. Notre équipe est disponible du lundi au samedi pour vous répondre en français et en anglais.</p>
      </div>

      <div class="card-grid card-grid--3" style="margin-bottom:3rem">
        <!-- WhatsApp -->
        <div class="photo-card" style="text-align:center">
          <div class="photo-card__body" style="align-items:center;gap:1rem">
            <div style="width:64px;height:64px;border-radius:50%;background:#2D4A22;display:flex;align-items:center;justify-content:center">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="#D4A017"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.855L.057 23.928l6.204-1.457A11.93 11.93 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0"/></svg>
            </div>
            <p class="photo-card__title">WhatsApp</p>
            <p style="font-size:.9rem;color:#5A6B52">La façon la plus rapide de nous joindre. Réponse immédiate pendant les heures de bureau.</p>
            <a href="https://wa.me/255753000000?text=Bonjour,%20je%20souhaite%20des%20informations%20sur%20un%20safari" style="color:#3D6B2E;font-weight:700;font-size:1.05rem" target="_blank" rel="noopener">+255 753 000 000</a>
          </div>
        </div>

        <!-- Email -->
        <div class="photo-card" style="text-align:center">
          <div class="photo-card__body" style="align-items:center;gap:1rem">
            <div style="width:64px;height:64px;border-radius:50%;background:#2D4A22;display:flex;align-items:center;justify-content:center">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="#D4A017"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            </div>
            <p class="photo-card__title">Email</p>
            <p style="font-size:.9rem;color:#5A6B52">Pour des demandes détaillées et des devis personnalisés. Réponse sous 24 heures.</p>
            <a href="mailto:info@tanzaniasafari.info" style="color:#3D6B2E;font-weight:700;font-size:1.05rem">info@tanzaniasafari.info</a>
          </div>
        </div>

        <!-- Téléphone -->
        <div class="photo-card" style="text-align:center">
          <div class="photo-card__body" style="align-items:center;gap:1rem">
            <div style="width:64px;height:64px;border-radius:50%;background:#2D4A22;display:flex;align-items:center;justify-content:center">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="#D4A017"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.62 10.79z"/></svg>
            </div>
            <p class="photo-card__title">Téléphone</p>
            <p style="font-size:.9rem;color:#5A6B52">Appelez-nous directement. Horaires : lundi–samedi, 6h–18h (EAT).</p>
            <a href="tel:+255753000000" style="color:#3D6B2E;font-weight:700;font-size:1.05rem">+255 753 000 000</a>
          </div>
        </div>
      </div>

      <!-- Bureau à Arusha -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start">
        <div style="background:white;border-radius:var(--radius-md);padding:2rem;box-shadow:var(--shadow-card)">
          <h3 style="margin-bottom:1rem;color:#2D4A22">Notre Bureau à Arusha</h3>
          <div style="display:flex;flex-direction:column;gap:1rem;font-size:.95rem;color:#5A6B52">
            <div style="display:flex;align-items:flex-start;gap:.75rem">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="#3D6B2E" style="flex-shrink:0;margin-top:2px"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              <div>
                <p style="font-weight:700;color:#2D4A22">Adresse</p>
                <p>Sokoine Road, Arusha, Tanzanie</p>
              </div>
            </div>
            <div style="display:flex;align-items:flex-start;gap:.75rem">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="#3D6B2E" style="flex-shrink:0;margin-top:2px"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
              <div>
                <p style="font-weight:700;color:#2D4A22">Horaires</p>
                <p>Lundi–Samedi : 6h00–18h00</p>
                <p>Dimanche : 8h00–14h00</p>
              </div>
            </div>
            <div style="display:flex;align-items:flex-start;gap:.75rem">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="#3D6B2E" style="flex-shrink:0;margin-top:2px"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              <div>
                <p style="font-weight:700;color:#2D4A22">Langues</p>
                <p>Français, Anglais, Swahili</p>
              </div>
            </div>
          </div>
        </div>
        <div style="border-radius:var(--radius-md);overflow:hidden;aspect-ratio:4/3;background:#e8ddd0">
          <img
            src="https://images.unsplash.com/photo-1489392191049-fc10c97e64b6?w=800&h=600&fit=crop&auto=format"
            alt="Vue sur le mont Kilimandjaro depuis la savane tanzanienne"
            width="600"
            height="450"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover"
          >
        </div>
      </div>
    </div>
  </section>

  <!-- FORMULAIRE DE CONTACT -->
  <section class="section section--gray">
    <div class="container" style="max-width:700px">
      <div class="section__header">
        <span class="chip chip--amber">Formulaire</span>
        <h2>Envoyez-nous un Message</h2>
        <p>Remplissez ce formulaire et nous vous répondrons dans les 24 heures avec une proposition personnalisée pour votre safari.</p>
      </div>

      <form
        action="https://formsubmit.co/info@tanzaniasafari.info"
        method="POST"
        style="background:white;border-radius:var(--radius-md);padding:2rem;box-shadow:var(--shadow-card);display:flex;flex-direction:column;gap:1.25rem"
      >
        <input type="hidden" name="_subject" value="Nouvelle demande safari depuis le site (FR)">
        <input type="hidden" name="_next" value="https://tanzaniasafari.info/fr/contact/">
        <input type="hidden" name="_captcha" value="false">

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
          <div>
            <label for="nom" style="display:block;font-weight:600;color:#2D4A22;margin-bottom:.4rem;font-size:.9rem">Nom complet *</label>
            <input
              type="text"
              id="nom"
              name="nom"
              required
              placeholder="Votre nom et prénom"
              style="width:100%;padding:.75rem 1rem;border:1.5px solid #d1d9ca;border-radius:var(--radius-sm);font-size:.95rem;font-family:inherit;transition:border-color .2s;box-sizing:border-box"
            >
          </div>
          <div>
            <label for="email" style="display:block;font-weight:600;color:#2D4A22;margin-bottom:.4rem;font-size:.9rem">Email *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="votre@email.com"
              style="width:100%;padding:.75rem 1rem;border:1.5px solid #d1d9ca;border-radius:var(--radius-sm);font-size:.95rem;font-family:inherit;transition:border-color .2s;box-sizing:border-box"
            >
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
          <div>
            <label for="telephone" style="display:block;font-weight:600;color:#2D4A22;margin-bottom:.4rem;font-size:.9rem">Téléphone</label>
            <input
              type="tel"
              id="telephone"
              name="telephone"
              placeholder="+33 6 00 00 00 00"
              style="width:100%;padding:.75rem 1rem;border:1.5px solid #d1d9ca;border-radius:var(--radius-sm);font-size:.95rem;font-family:inherit;transition:border-color .2s;box-sizing:border-box"
            >
          </div>
          <div>
            <label for="voyageurs" style="display:block;font-weight:600;color:#2D4A22;margin-bottom:.4rem;font-size:.9rem">Nombre de voyageurs</label>
            <select
              id="voyageurs"
              name="voyageurs"
              style="width:100%;padding:.75rem 1rem;border:1.5px solid #d1d9ca;border-radius:var(--radius-sm);font-size:.95rem;font-family:inherit;background:white;box-sizing:border-box"
            >
              <option value="">Sélectionner...</option>
              <option value="1">1 personne</option>
              <option value="2">2 personnes</option>
              <option value="3-4">3–4 personnes</option>
              <option value="5-6">5–6 personnes</option>
              <option value="7+">7 personnes ou plus</option>
            </select>
          </div>
        </div>

        <div>
          <label for="dates" style="display:block;font-weight:600;color:#2D4A22;margin-bottom:.4rem;font-size:.9rem">Dates de voyage</label>
          <input
            type="text"
            id="dates"
            name="dates"
            placeholder="Ex. : juillet 2026, 10 jours, flexible"
            style="width:100%;padding:.75rem 1rem;border:1.5px solid #d1d9ca;border-radius:var(--radius-sm);font-size:.95rem;font-family:inherit;transition:border-color .2s;box-sizing:border-box"
          >
        </div>

        <div>
          <label for="message" style="display:block;font-weight:600;color:#2D4A22;margin-bottom:.4rem;font-size:.9rem">Message *</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Décrivez votre safari idéal : parcs à visiter, type d'hébergement (lodge ou camping), activités souhaitées, budget estimé..."
            style="width:100%;padding:.75rem 1rem;border:1.5px solid #d1d9ca;border-radius:var(--radius-sm);font-size:.95rem;font-family:inherit;resize:vertical;transition:border-color .2s;box-sizing:border-box"
          ></textarea>
        </div>

        <button
          type="submit"
          class="btn btn--primary btn--lg"
          style="align-self:flex-start"
        >
          Envoyer ma demande
        </button>
        <p style="font-size:.8rem;color:#5A6B52">* Champs obligatoires. Vos données sont utilisées uniquement pour répondre à votre demande.</p>
      </form>
    </div>
  </section>

  <!-- TIKTOK -->
  <SafariTikTok category="general" lang="fr" />

  <!-- CTA -->
  <section class="section section--green">
    <div class="container" style="text-align:center">
      <h2 style="color:white;margin-bottom:.75rem">Commencez votre Aventure Africaine</h2>
      <p style="color:rgba(255,255,255,.85);margin-bottom:1.5rem;max-width:500px;margin-left:auto;margin-right:auto">Écrivez-nous aujourd'hui et recevez une proposition personnalisée en moins de 24 heures. Votre safari de rêve commence ici.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="https://wa.me/255753000000?text=Bonjour,%20je%20veux%20planifier%20un%20safari" class="btn btn--amber btn--lg" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/fr/prix/" class="btn btn--outline-white btn--lg">Voir les tarifs</a>
        <a href="/fr/comment-venir/" class="btn btn--outline-white btn--lg">Comment venir</a>
      </div>
    </div>
  </section>
</BaseLayout>
