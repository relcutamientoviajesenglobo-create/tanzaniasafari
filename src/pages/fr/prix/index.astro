---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { touristAttraction, faqPage } from '../../../i18n/schema';
import SafariTikTok from '../../../components/SafariTikTok.astro';
import PhotoGallery from '../../../components/PhotoGallery.astro';

const lang = 'fr';
const title = 'Tarifs Tanzania Safari 2026 — Prix, Forfaits & Réservations';
const description = 'Consultez les tarifs 2026 pour vos safaris en Tanzanie : forfaits tout compris à partir de 2 450 $ par personne. Guides, hébergement, repas et transferts aéroport inclus. Devis personnalisé gratuit.';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const galleryImages = [
  { src: 'https://images.unsplash.com/photo-1547471080-7cc2caa01a7e?w=600&h=400&fit=crop&auto=format', alt: 'Troupeau d\'éléphants dans la savane du Serengeti inclus dans nos forfaits safari' },
  { src: 'https://images.unsplash.com/photo-1516426122078-c23e76319801?w=600&h=400&fit=crop&auto=format', alt: 'Safari classique en 4x4 avec toit ouvrant sur les plaines du Serengeti' },
  { src: 'https://images.unsplash.com/photo-1504598318550-17eba1008a68?w=600&h=400&fit=crop&auto=format', alt: 'Vol en montgolfière au lever du soleil au-dessus du Serengeti' },
  { src: 'https://images.unsplash.com/photo-1546182990-dffeafbe841d?w=600&h=400&fit=crop&auto=format', alt: 'Lion au repos lors d\'une observation du Big Five en Tanzanie' },
  { src: 'https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=600&h=400&fit=crop&auto=format', alt: 'Lodge de luxe inclus dans les forfaits premium de safari Tanzania' },
  { src: 'https://images.unsplash.com/photo-1493246507139-91e8fad9978e?w=600&h=400&fit=crop&auto=format', alt: 'Piscine à débordement du lodge avec vue sur la savane africaine' },
];

const breadcrumbs = [
  { label: 'Tarifs' },
];

const faqs = [
  { question: 'Les prix incluent-ils l\'hébergement ?', answer: 'Oui, tous nos forfaits multi-jours incluent l\'hébergement en lodge ou campement, la pension complète, le transport en 4x4 et un guide professionnel bilingue. Aucun frais caché.' },
  { question: 'Y a-t-il des réductions pour les enfants et les familles ?', answer: 'Les enfants de moins de 5 ans voyagent gratuitement. De 5 à 12 ans, ils bénéficient de 50 % de réduction sur la plupart des forfaits. Les droits d\'entrée dans les parcs nationaux ont également des tarifs enfants spéciaux.' },
  { question: 'Quels modes de paiement acceptez-vous ?', answer: 'Nous acceptons les virements bancaires, les cartes de crédit/débit (Visa, Mastercard) et PayPal. Un acompte de 30 % est requis pour confirmer la réservation, le solde est dû 30 jours avant le départ.' },
  { question: 'Puis-je personnaliser un forfait ?', answer: 'Absolument. Tous nos forfaits sont entièrement personnalisables. Contactez-nous avec vos dates préférées, les parcs souhaités et votre type d\'hébergement pour obtenir un devis sur mesure sans engagement.' },
  { question: 'Quelle est la politique d\'annulation ?', answer: 'Annulation gratuite jusqu\'à 60 jours avant le départ. Entre 30 et 60 jours : retenue de 30 %. Moins de 30 jours : retenue de 50 %. Nous vous recommandons de souscrire une assurance voyage.' },
];

const schema = [
  touristAttraction({
    name: 'Tarifs Tanzania Safari 2026',
    description,
    url: 'https://tanzaniasafari.info/fr/prix/',
  }),
  faqPage(faqs),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/fr/prix/"
  schema={schema}
  breadcrumbs={breadcrumbs}
  lang={lang}
>
  <Header slot="header" lang={lang} />
  <Footer slot="footer" lang={lang} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__acacia hero__acacia--tr" style="color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--amber">Tarifs 2026</span>
        <h1 class="hero__title">Tarifs Tanzania Safari</h1>
        <p class="hero__desc">Des forfaits tout compris sans mauvaises surprises. Transport, hébergement, repas, guides experts et droits d'entrée inclus dans chaque prix affiché.</p>
        <div class="hero__actions">
          <a href="/fr/contact/" class="btn btn--primary btn--lg">Demander un devis</a>
          <a href="https://wa.me/255753000000?text=Bonjour,%20je%20voudrais%20des%20informations%20sur%20vos%20tarifs%20safari%202026" class="btn btn--outline btn--lg" target="_blank" rel="noopener">WhatsApp</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img
            src="https://images.unsplash.com/photo-1547471080-7cc2caa01a7e?w=800&h=600&fit=crop&auto=format"
            alt="Troupeau d'éléphants dans le Serengeti en Tanzanie"
            width="600"
            height="480"
            loading="eager"
          >
        </div>
      </div>
    </div>
  </section>

  <!-- FORFAITS PRINCIPAUX -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="chip chip--green">Forfaits</span>
        <h2>Nos Forfaits Safari</h2>
        <p>Choisissez le forfait qui correspond à vos envies et à votre budget. Chacun peut être personnalisé selon vos préférences.</p>
      </div>

      <div class="card-grid card-grid--3">
        <!-- Safari Classique -->
        <div class="photo-card" style="border:2px solid #d1d9ca;position:relative">
          <div class="photo-card__img" style="background:#F5F0E8;aspect-ratio:auto;padding:2rem;text-align:center">
            <div style="display:flex;flex-direction:column;align-items:center;gap:.5rem">
              <span class="chip chip--green">5 Jours / 4 Nuits</span>
              <p style="font-family:var(--font-head);font-size:2.8rem;font-weight:800;color:#2D4A22;line-height:1">$2 450</p>
              <p style="font-size:.85rem;color:#5A6B52">par personne (base double)</p>
            </div>
          </div>
          <div class="photo-card__body">
            <p class="photo-card__title" style="font-size:1.2rem">Safari Classique</p>
            <p style="font-size:.88rem;color:#5A6B52;margin-bottom:.75rem">Notre formule la plus populaire pour découvrir les incontournables de la faune tanzanienne.</p>
            <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.5rem;font-size:.88rem;color:#3D4B36">
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Serengeti + Ngorongoro + Tarangire
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Lodge 3 étoiles ou campement confortable
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Game drives matin et soir inclus
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Pension complète incluse
              </li>
            </ul>
            <div style="margin-top:1.25rem">
              <span style="background:#FFF3CD;color:#B8860B;padding:.25rem .75rem;border-radius:20px;font-size:.8rem;font-weight:700">Le plus populaire</span>
            </div>
          </div>
        </div>

        <!-- Safari Premium -->
        <div class="photo-card" style="border:3px solid #2D4A22;position:relative;transform:scale(1.02)">
          <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:#2D4A22;color:white;padding:.3rem 1.25rem;border-radius:20px;font-size:.8rem;font-weight:700;white-space:nowrap;z-index:1">MEILLEUR RAPPORT QUALITE-PRIX</div>
          <div class="photo-card__img" style="background:#2D4A22;aspect-ratio:auto;padding:2rem;text-align:center">
            <div style="display:flex;flex-direction:column;align-items:center;gap:.5rem">
              <span style="background:rgba(212,160,23,.2);color:#D4A017;padding:.3rem .75rem;border-radius:20px;font-size:.8rem;font-weight:700">7 Jours / 6 Nuits</span>
              <p style="font-family:var(--font-head);font-size:2.8rem;font-weight:800;color:#D4A017;line-height:1">$3 800</p>
              <p style="font-size:.85rem;color:rgba(255,255,255,.7)">par personne (base double)</p>
            </div>
          </div>
          <div class="photo-card__body">
            <p class="photo-card__title" style="font-size:1.2rem">Safari Premium</p>
            <p style="font-size:.88rem;color:#5A6B52;margin-bottom:.75rem">La formule idéale pour une immersion complète dans la faune sauvage tanzanienne avec hébergement de luxe.</p>
            <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.5rem;font-size:.88rem;color:#3D4B36">
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                4 parcs nationaux dont Selous
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Lodge 4–5 étoiles avec piscine
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Guide expert francophone dédié
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Dîner en brousse inclus
              </li>
            </ul>
            <div style="margin-top:1.25rem">
              <a href="/fr/contact/" class="btn btn--primary" style="font-size:.9rem">Réserver ce forfait</a>
            </div>
          </div>
        </div>

        <!-- Grand Safari -->
        <div class="photo-card" style="border:2px solid #d1d9ca">
          <div class="photo-card__img" style="background:#3D1A00;aspect-ratio:auto;padding:2rem;text-align:center">
            <div style="display:flex;flex-direction:column;align-items:center;gap:.5rem">
              <span style="background:rgba(212,160,23,.2);color:#D4A017;padding:.3rem .75rem;border-radius:20px;font-size:.8rem;font-weight:700">10 Jours / 9 Nuits</span>
              <p style="font-family:var(--font-head);font-size:2.8rem;font-weight:800;color:#D4A017;line-height:1">$5 200</p>
              <p style="font-size:.85rem;color:rgba(255,255,255,.7)">par personne (base double)</p>
            </div>
          </div>
          <div class="photo-card__body">
            <p class="photo-card__title" style="font-size:1.2rem">Grand Safari</p>
            <p style="font-size:.88rem;color:#5A6B52;margin-bottom:.75rem">L'expérience safari ultime pour les passionnés de nature et de photographie animalière.</p>
            <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.5rem;font-size:.88rem;color:#3D4B36">
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Circuit complet 6 parcs et réserves
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Lodges de luxe premium
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Vol en montgolfière au Serengeti
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="14" height="14" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Marche en brousse avec rangers
              </li>
            </ul>
            <div style="margin-top:1.25rem">
              <span style="background:#F3E8FF;color:#6B21A8;padding:.25rem .75rem;border-radius:20px;font-size:.8rem;font-weight:700">Ultime</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CE QUE TOUS LES FORFAITS INCLUENT -->
  <section class="section section--gray">
    <div class="container">
      <div class="section__header">
        <span class="chip chip--green">Inclus</span>
        <h2>Ce que tous les forfaits incluent</h2>
        <p>Chaque forfait est pensé pour vous offrir une expérience complète, sans frais supplémentaires inattendus.</p>
      </div>

      <div class="service-cards" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr))">
        <div class="service-card">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="#D4A017"><path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"/></svg>
          <p class="service-card__title">4x4 Toyota Land Cruiser</p>
          <p class="service-card__desc">Véhicule safari avec toit ouvrant, air conditionné, chargeurs USB et glacière. Maximum 6 passagers pour le confort de tous.</p>
        </div>
        <div class="service-card">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="#D4A017"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <p class="service-card__title">Droits d'entrée des parcs</p>
          <p class="service-card__desc">Tous les droits d'entrée des parcs nationaux visités sont compris dans le prix du forfait. Aucun supplément à payer sur place.</p>
        </div>
        <div class="service-card">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="#D4A017"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
          <p class="service-card__title">Guides naturalistes experts</p>
          <p class="service-card__desc">Guides certifiés francophones avec plus de 10 ans d'expérience dans les parcs tanzaniens. Passion et connaissance approfondie de la faune.</p>
        </div>
        <div class="service-card">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="#D4A017"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>
          <p class="service-card__title">Transferts aéroport</p>
          <p class="service-card__desc">Prise en charge à l'aéroport du Kilimandjaro (JRO) à l'arrivée et au départ. Aucun stress logistique dès votre atterrissage en Tanzanie.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- INFORMATIONS IMPORTANTES -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="chip chip--amber">Informations</span>
        <h2>Informations importantes sur les tarifs</h2>
        <p>Tout ce que vous devez savoir avant de réserver votre safari en Tanzanie.</p>
      </div>

      <div class="card-grid card-grid--2" style="gap:1.5rem">
        <div style="background:#F5F0E8;border-radius:var(--radius-md);padding:1.75rem">
          <h3 style="color:#2D4A22;margin-bottom:.75rem;font-size:1.1rem">Enfants & Familles</h3>
          <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.5rem;font-size:.9rem;color:#5A6B52">
            <li>• Moins de 5 ans : gratuit</li>
            <li>• 5–12 ans : 50 % de réduction</li>
            <li>• Plus de 12 ans : tarif adulte</li>
            <li>• Forfaits famille personnalisables sur demande</li>
          </ul>
        </div>
        <div style="background:#F5F0E8;border-radius:var(--radius-md);padding:1.75rem">
          <h3 style="color:#2D4A22;margin-bottom:.75rem;font-size:1.1rem">Variations saisonnières</h3>
          <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.5rem;font-size:.9rem;color:#5A6B52">
            <li>• Haute saison (juin–octobre) : +15 %</li>
            <li>• Saison des pluies (avril–mai) : –20 %</li>
            <li>• Grande Migration (juillet–août) : tarif spécial</li>
            <li>• Basse saison : offres spéciales disponibles</li>
          </ul>
        </div>
        <div style="background:#F5F0E8;border-radius:var(--radius-md);padding:1.75rem">
          <h3 style="color:#2D4A22;margin-bottom:.75rem;font-size:1.1rem">Non inclus dans le prix</h3>
          <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.5rem;font-size:.9rem;color:#5A6B52">
            <li>• Vols internationaux</li>
            <li>• Visa d'entrée en Tanzanie (environ 50 $)</li>
            <li>• Assurance voyage (fortement recommandée)</li>
            <li>• Pourboires pour guides et personnel</li>
            <li>• Activités optionnelles (montgolfière, plongée)</li>
          </ul>
        </div>
        <div style="background:#F5F0E8;border-radius:var(--radius-md);padding:1.75rem">
          <h3 style="color:#2D4A22;margin-bottom:.75rem;font-size:1.1rem">Paiement & Annulation</h3>
          <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.5rem;font-size:.9rem;color:#5A6B52">
            <li>• Acompte : 30 % à la réservation</li>
            <li>• Solde : 30 jours avant le départ</li>
            <li>• Visa, Mastercard, virement bancaire, PayPal</li>
            <li>• Annulation gratuite jusqu'à 60 jours avant</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--gray">
    <div class="container" style="max-width:800px">
      <div class="section__header">
        <h2>Questions Fréquentes sur les Tarifs</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">{faq.question}</summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <PhotoGallery images={galleryImages} title="Galerie — Tanzania Safari 2026" />
  <SafariTikTok category="general" lang="fr" />

  <!-- CTA -->
  <section class="section section--green">
