---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lang = 'en';
const title = '404 — Page Not Found | Tanzania Safari';
const description = 'The page you are looking for does not exist. Browse our safari packages, national parks, and travel guides.';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;
---

<BaseLayout title={title} description={description} schema={[]} lang={lang}>
  <Header slot="header" lang={lang} />
  <Footer slot="footer" lang={lang} />

  <section class="section" style="text-align:center;padding:6rem 1rem">
    <div class="container" style="max-width:600px">
      <div style="opacity:.15;pointer-events:none;color:#2D4A22;margin-bottom:2rem">
        <Fragment set:html={ACACIA_LARGE} />
      </div>
      <span style="font-size:5rem;font-family:var(--font-head);font-weight:800;color:var(--mc-green);display:block;line-height:1">404</span>
      <h1 style="font-size:1.75rem;margin:.75rem 0">Page Not Found</h1>
      <p style="color:var(--mc-text-muted);margin-bottom:2rem;font-size:1.05rem">It seems this trail leads nowhere. The page you are looking for may have moved or no longer exists.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/" class="btn btn--primary btn--lg">Back to Homepage</a>
        <a href="/safaris/" class="btn btn--outline btn--lg">Explore Safaris</a>
      </div>
      <div style="margin-top:3rem;display:flex;gap:1.5rem;justify-content:center;flex-wrap:wrap;font-size:.9rem">
        <a href="/prices/" style="color:#3D6B2E;font-weight:600">Prices</a>
        <a href="/national-parks/" style="color:#3D6B2E;font-weight:600">National Parks</a>
        <a href="/blog/" style="color:#3D6B2E;font-weight:600">Blog</a>
        <a href="/contact/" style="color:#3D6B2E;font-weight:600">Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
