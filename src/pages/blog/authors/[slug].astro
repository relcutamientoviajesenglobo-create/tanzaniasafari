---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const lang = 'en';

// Filter English authors (starting with 'en-')
export async function getStaticPaths() {
  const authors = await getCollection('authors');
  return authors
    .filter(a => a.id.startsWith('en-'))
    .map(author => ({
      params: { slug: author.id.replace('en-', '') },
      props: { author },
    }));
}

const { author } = Astro.props;

// Get all English posts
const allPosts = await getCollection('blog');
const authorPosts = allPosts
  .filter(p => p.slug.startsWith('en-') && p.data.authorSlug === author.id)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const breadcrumbs = [
  { label: 'Blog', href: '/blog/' },
  { label: author.data.name },
];

const title = `${author.data.name} — Safari Tanzania Blog`;
const description = author.data.bio;
---

<BaseLayout title={title} description={description} schema={[]} breadcrumbs={breadcrumbs} lang={lang}>
  <Header slot="header" lang={lang} />
  <Footer slot="footer" lang={lang} />

  <!-- Author Header -->
  <section class="section" style="padding-bottom:2rem">
    <div class="container" style="max-width:700px;text-align:center">
      <img
        src={author.data.avatar}
        alt={author.data.name}
        width="120"
        height="120"
        loading="eager"
        style="width:120px;height:120px;border-radius:50%;object-fit:cover;margin:0 auto 1.25rem;border:4px solid var(--mc-amber)"
      >
      <h1 style="margin-bottom:.35rem">{author.data.name}</h1>
      <p style="color:var(--mc-green-mid);font-weight:700;font-size:.95rem;margin-bottom:1rem">{author.data.role}</p>
      <p style="max-width:550px;margin:0 auto 1.5rem">{author.data.bio}</p>

      {author.data.expertise && author.data.expertise.length > 0 && (
        <div style="display:flex;flex-wrap:wrap;gap:.5rem;justify-content:center;margin-bottom:1.5rem">
          {author.data.expertise.map((skill: string) => (
            <span class="chip chip--green" style="font-size:.78rem">{skill}</span>
          ))}
        </div>
      )}

      {author.data.social && (
        <div style="display:flex;gap:1rem;justify-content:center">
          {author.data.social.instagram && (
            <a href={author.data.social.instagram} target="_blank" rel="noopener" style="color:#3D6B2E;font-weight:700;font-size:.9rem">Instagram</a>
          )}
          {author.data.social.facebook && (
            <a href={author.data.social.facebook} target="_blank" rel="noopener" style="color:#3D6B2E;font-weight:700;font-size:.9rem">Facebook</a>
          )}
          {author.data.social.tiktok && (
            <a href={author.data.social.tiktok} target="_blank" rel="noopener" style="color:#3D6B2E;font-weight:700;font-size:.9rem">TikTok</a>
          )}
          {author.data.social.pinterest && (
            <a href={author.data.social.pinterest} target="_blank" rel="noopener" style="color:#3D6B2E;font-weight:700;font-size:.9rem">Pinterest</a>
          )}
        </div>
      )}
    </div>
  </section>

  <!-- Author Posts -->
  <section class="section section--gray">
    <div class="container">
      <h2 style="text-align:center;margin-bottom:2rem">Articles by {author.data.name}</h2>
      {authorPosts.length > 0 ? (
        <div class="card-grid card-grid--3" style="grid-template-columns:repeat(auto-fit,minmax(300px,1fr))">
          {authorPosts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug.replace('en-', '')}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              author={post.data.author}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              category={post.data.category}
              lang={lang}
            />
          ))}
        </div>
      ) : (
        <div style="text-align:center;padding:3rem 0">
          <p>No articles published yet. Check back soon.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
