---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import BlogSearch from '../../components/blog/BlogSearch.astro';
import SafariTikTok from '../../components/SafariTikTok.astro';
import { getCollection } from 'astro:content';
import { languages } from '../../i18n/config';

const lang = 'en';
const title = 'Tanzania Safari Blog — Guides, Tips & Travel Stories';
const description = 'Explore our blog for Tanzania safari guides, wildlife photography tips, travel planning advice, Masai culture insights, and accommodation reviews.';

// Filter English posts (starting with 'en-')
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.slug.startsWith('en-'))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const breadcrumbs = [
  { label: 'Blog' },
];

// Silo categories for navigation
const searchPosts = posts.map(post => ({
  title: post.data.title,
  description: post.data.description,
  slug: post.slug.replace(/^(en|es|de|fr)-/, ''),
  image: post.data.image,
  category: post.data.category,
  tags: post.data.tags,
}));

const silos = [
  { label: 'Tanzania Safaris', href: '/blog/tanzania-safaris/' },
  { label: 'Adventure Activities', href: '/blog/adventure-activities/' },
  { label: 'Lodges & Camps', href: '/blog/lodges-camps/' },
  { label: 'Travel Guides', href: '/blog/travel-guides/' },
  { label: 'Masai Culture', href: '/blog/masai-culture/' },
];
---

<BaseLayout title={title} description={description} schema={[]} breadcrumbs={breadcrumbs} lang={lang}>
  <Header slot="header" lang={lang} />
  <Footer slot="footer" lang={lang} />

  <!-- Hero -->
  <section class="hero" style="padding-bottom:2rem">
    <div class="container">
      <div style="text-align:center;max-width:700px;margin:0 auto">
        <span class="chip chip--green">Blog</span>
        <h1 style="margin-top:.75rem">Tanzania Safari Blog</h1>
        <p style="margin-bottom:1.5rem">Guides, tips, and stories from the African bush. Everything you need to plan the perfect Tanzania safari, from wildlife photography to Masai cultural experiences.</p>
      </div>
    </div>
  </section>

  <!-- Silo Navigation -->
  <section style="padding:0 0 2rem">
    <div class="container">
      <div style="display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center">
        {silos.map(silo => (
          <a href={silo.href} class="chip chip--amber" style="text-decoration:none;font-size:.85rem;padding:.4rem 1rem">{silo.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Search -->
  <section style="padding:0 0 2rem">
    <div class="container">
      <BlogSearch posts={searchPosts} lang={lang} />
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="section section--gray">
    <div class="container">
      {posts.length > 0 ? (
        <>
          <p style="text-align:center;margin-bottom:2.5rem;color:var(--mc-text-muted)">{posts.length} articles across {silos.length} categories</p>

          {/* Featured post — first post displayed as a large card */}
          {posts.length > 0 && (
            <a href={`/blog/${posts[0].slug.replace('en-', '')}/`} class="blog-featured-card">
              <div class="blog-featured-card__img">
                <img src={posts[0].data.image} alt={posts[0].data.imageAlt} width="700" height="400" loading="eager" />
              </div>
              <div class="blog-featured-card__body">
                <span class="blog-featured-card__chip">{posts[0].data.category}</span>
                <h2 class="blog-featured-card__title">{posts[0].data.title}</h2>
                <p class="blog-featured-card__desc">{posts[0].data.description}</p>
                <div class="blog-featured-card__meta">
                  <span>{posts[0].data.author}</span>
                  <span style="opacity:.4">·</span>
                  <time datetime={posts[0].data.publishDate instanceof Date ? posts[0].data.publishDate.toISOString().split('T')[0] : String(posts[0].data.publishDate)}>
                    {posts[0].data.publishDate.toLocaleDateString(languages[lang].dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  {posts[0].data.readingTime && (
                    <>
                      <span style="opacity:.4">·</span>
                      <span>{posts[0].data.readingTime} min read</span>
                    </>
                  )}
                </div>
              </div>
            </a>
          )}

          {/* Remaining posts as regular cards */}
          {posts.length > 1 && (
            <div class="card-grid card-grid--3" style="grid-template-columns:repeat(auto-fit,minmax(300px,1fr))">
              {posts.slice(1).map(post => (
                <BlogCard
                  title={post.data.title}
                  description={post.data.description}
                  slug={post.slug.replace('en-', '')}
                  image={post.data.image}
                  imageAlt={post.data.imageAlt}
                  author={post.data.author}
                  publishDate={post.data.publishDate}
                  readingTime={post.data.readingTime}
                  category={post.data.category}
                  lang={lang}
                />
              ))}
            </div>
          )}
        </>
      ) : (
        <div style="text-align:center;padding:4rem 0">
          <span style="font-size:3rem;display:block;margin-bottom:1rem">📝</span>
          <h2 style="font-size:1.5rem;margin-bottom:.75rem">Coming Soon</h2>
          <p style="max-width:400px;margin:0 auto">We are working on new articles about Tanzania safaris, wildlife photography, and travel tips. Check back soon for fresh content.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Safari TikTok -->
  <SafariTikTok category="general" lang={lang} />

  <!-- CTA -->
  <section class="section section--green">
    <div class="container" style="text-align:center;position:relative">
      <div style="position:absolute;top:-30px;right:0;opacity:.12;pointer-events:none;color:#D4A017">
        <Fragment set:html={ACACIA_LARGE} />
      </div>
      <h2 style="color:white;margin-bottom:.75rem">Ready for Your Tanzania Safari?</h2>
      <p style="color:rgba(255,255,255,.85);margin-bottom:1.5rem;max-width:520px;margin-left:auto;margin-right:auto">Turn inspiration into reality. Check our prices and start planning your adventure in the Serengeti and beyond.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/prices/" class="btn btn--primary btn--lg">See 2026 Prices</a>
        <a href="/how-to-get-here/" class="btn btn--outline-white btn--lg" style="border-color:white;color:white">How to Get Here</a>
      </div>
    </div>
  </section>
</BaseLayout>
