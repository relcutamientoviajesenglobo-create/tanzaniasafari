---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const lang = 'en';
const title = 'Adventure Activities in Tanzania — Guides & Experiences';
const description = 'Articles about adventure activities in Tanzania: hot air balloon rides, bush walks, wildlife photography, night safaris, and unique experiences beyond the traditional game drive.';

// Filter English posts by silo
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.slug.startsWith('en-') && post.data.silo === 'actividades-aventura')
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const breadcrumbs = [
  { label: 'Blog', href: '/blog/' },
  { label: 'Adventure Activities' },
];
---

<BaseLayout title={title} description={description} schema={[]} breadcrumbs={breadcrumbs} lang={lang}>
  <Header slot="header" lang={lang} />
  <Footer slot="footer" lang={lang} />

  <!-- Hero -->
  <section class="hero" style="padding-bottom:2rem">
    <div class="container">
      <div style="text-align:center;max-width:700px;margin:0 auto">
        <span class="chip chip--green">Blog Category</span>
        <h1 style="margin-top:.75rem">Adventure Activities</h1>
        <p>Go beyond the game drive. Discover hot air balloon rides over the Serengeti, guided bush walks with Masai warriors, night safari encounters, wildlife photography masterclasses, and more adrenaline-fueled experiences in Tanzania.</p>
      </div>
    </div>
  </section>

  <!-- Posts -->
  <section class="section section--gray">
    <div class="container">
      {posts.length > 0 ? (
        <>
          <p style="text-align:center;margin-bottom:2.5rem;color:var(--mc-text-muted)">{posts.length} articles published</p>
          <div class="card-grid card-grid--3" style="grid-template-columns:repeat(auto-fit,minmax(300px,1fr))">
            {posts.map(post => (
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                slug={post.slug.replace('en-', '')}
                image={post.data.image}
                imageAlt={post.data.imageAlt}
                author={post.data.author}
                publishDate={post.data.publishDate}
                readingTime={post.data.readingTime}
                category={post.data.category}
                lang={lang}
              />
            ))}
          </div>
        </>
      ) : (
        <div style="text-align:center;padding:4rem 0">
          <span style="font-size:3rem;display:block;margin-bottom:1rem">🎈</span>
          <h2 style="font-size:1.5rem;margin-bottom:.75rem">Articles Coming Soon</h2>
          <p style="max-width:400px;margin:0 auto">We are preparing articles about adventure activities in Tanzania. Check back soon or <a href="/blog/" style="color:#3D6B2E;font-weight:700">browse all articles</a>.</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--green">
    <div class="container" style="text-align:center;position:relative">
      <div style="position:absolute;top:-30px;right:0;opacity:.12;pointer-events:none;color:#D4A017">
        <Fragment set:html={ACACIA_LARGE} />
      </div>
      <h2 style="color:white;margin-bottom:.75rem">Ready for Adventure?</h2>
      <p style="color:rgba(255,255,255,.85);margin-bottom:1.5rem;max-width:520px;margin-left:auto;margin-right:auto">From hot air balloons to walking safaris, Tanzania offers unforgettable adventures. Check our prices to start planning.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/prices/" class="btn btn--primary btn--lg">See 2026 Prices</a>
        <a href="/contact/" class="btn btn--outline-white btn--lg" style="border-color:white;color:white">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
