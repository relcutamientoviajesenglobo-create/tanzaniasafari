---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { touristAttraction, faqPage } from '../../../i18n/schema';

const title = 'Precios Safari Tanzania 2026 — Tarifas, Paquetes y Reservas';
const description = 'Consulta los precios actualizados 2026 para safaris en Tanzania: safari de un dia desde $150 USD, multi-dia desde $800 USD, globo aerostatico $500 USD. Paquetes todo incluido.';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const breadcrumbs = [
  { label: 'Precios' },
];

const faqs = [
  { question: 'Los precios incluyen alojamiento?', answer: 'Si, todos los paquetes multi-dia incluyen alojamiento en lodge o campamento, pension completa, transporte en 4x4 y guia profesional bilingue.' },
  { question: 'Hay descuentos para ninos?', answer: 'Ninos menores de 5 anos son gratis. De 5 a 12 anos tienen un 50% de descuento en la mayoria de paquetes. Los precios de los parques nacionales tienen tarifas infantiles especiales.' },
  { question: 'Que metodos de pago aceptan?', answer: 'Aceptamos transferencia bancaria, tarjeta de credito/debito (Visa, Mastercard) y PayPal. Se requiere un deposito del 30% para confirmar la reserva.' },
  { question: 'Puedo personalizar un paquete?', answer: 'Por supuesto. Todos nuestros paquetes son personalizables. Contactanos con tus preferencias de fechas, parques y tipo de alojamiento para una cotizacion a medida.' },
];

const schema = [
  touristAttraction({
    name: 'Precios Safari Tanzania 2026',
    description,
    url: 'https://safaritanzania.info/precios/',
  }),
  faqPage(faqs),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/precios/"
  schema={schema}
  breadcrumbs={breadcrumbs}
>
  <Header slot="header" />
  <Footer slot="footer" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__acacia hero__acacia--tr" style="color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--green">Precios 2026</span>
        <h1 class="hero__title">Precios Safari Tanzania</h1>
        <p class="hero__desc">Tarifas actualizadas para 2026. Paquetes todo incluido con transporte, alojamiento, comidas y guias expertos. Sin costos ocultos.</p>
        <div class="hero__actions">
          <a href="/contacto/" class="btn btn--primary btn--lg">Solicitar Cotizacion</a>
          <a href="https://wa.me/255753000000?text=Hola,%20quiero%20informacion%20de%20precios" class="btn btn--outline btn--lg" target="_blank" rel="noopener">WhatsApp</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img
            src="https://images.unsplash.com/photo-1547471080-7cc2caa01a7e?w=800&h=600&fit=crop&auto=format"
            alt="Manada de elefantes en safari en Tanzania"
            width="600"
            height="480"
            loading="eager"
          >
        </div>
      </div>
    </div>
  </section>

  <!-- PAQUETES PRINCIPALES -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="chip chip--amber">Paquetes</span>
        <h2>Nuestros Paquetes de Safari</h2>
        <p>Elige el paquete que mejor se adapte a tu tiempo y presupuesto. Todos incluyen transporte, guia y comidas.</p>
      </div>

      <div class="card-grid card-grid--3">
        <!-- Safari de un dia -->
        <div class="photo-card" style="border:3px solid transparent">
          <div class="photo-card__img" style="background:#F5F0E8;aspect-ratio:auto;padding:2rem;text-align:center">
            <div style="display:flex;flex-direction:column;align-items:center;gap:.5rem">
              <span class="chip chip--green">1 Dia</span>
              <p style="font-family:var(--font-head);font-size:2.5rem;font-weight:800;color:#2D4A22;line-height:1">$150 <span style="font-size:1rem;font-weight:400">- $250</span></p>
              <p style="font-size:.85rem;color:#5A6B52">USD por persona</p>
            </div>
          </div>
          <div class="photo-card__body">
            <p class="photo-card__title">Safari de Un Dia</p>
            <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.5rem;font-size:.88rem;color:#5A6B52">
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Game drive matutino o vespertino
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Transporte 4x4 desde Arusha
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Almuerzo picnic incluido
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Guia profesional bilingue
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Entradas al parque incluidas
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Agua embotellada
              </li>
            </ul>
            <div style="margin-top:auto;padding-top:1rem">
              <a href="/contacto/" class="btn btn--primary" style="width:100%;justify-content:center">Reservar</a>
            </div>
          </div>
        </div>

        <!-- Multi-dia (destacado) -->
        <div class="photo-card" style="border:3px solid #D4A017;position:relative">
          <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:#D4A017;color:#2D4A22;font-family:var(--font-head);font-weight:800;font-size:.75rem;padding:.25rem 1rem;border-radius:0 0 8px 8px;z-index:2">MAS POPULAR</div>
          <div class="photo-card__img" style="background:#2D4A22;aspect-ratio:auto;padding:2rem;text-align:center">
            <div style="display:flex;flex-direction:column;align-items:center;gap:.5rem">
              <span class="chip chip--amber">3-7 Dias</span>
              <p style="font-family:var(--font-head);font-size:2.5rem;font-weight:800;color:#D4A017;line-height:1">$800 <span style="font-size:1rem;font-weight:400;color:rgba(255,255,255,.7)">- $2,500</span></p>
              <p style="font-size:.85rem;color:rgba(255,255,255,.7)">USD por persona</p>
            </div>
          </div>
          <div class="photo-card__body">
            <p class="photo-card__title">Safari Multi-Dia</p>
            <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.5rem;font-size:.88rem;color:#5A6B52">
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                3 a 7 dias de safari completo
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Alojamiento lodge o campamento
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Pension completa (todas las comidas)
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Multiples parques nacionales
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Game drives matutinos y vespertinos
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Transporte 4x4 + guia experto
              </li>
            </ul>
            <div style="margin-top:auto;padding-top:1rem">
              <a href="/contacto/" class="btn btn--primary" style="width:100%;justify-content:center;background:#D4A017;color:#2D4A22;border-color:#D4A017">Reservar Ahora</a>
            </div>
          </div>
        </div>

        <!-- Globo aerostatico -->
        <div class="photo-card" style="border:3px solid transparent">
          <div class="photo-card__img" style="background:#F5F0E8;aspect-ratio:auto;padding:2rem;text-align:center">
            <div style="display:flex;flex-direction:column;align-items:center;gap:.5rem">
              <span class="chip chip--green">Experiencia</span>
              <p style="font-family:var(--font-head);font-size:2.5rem;font-weight:800;color:#2D4A22;line-height:1">$500</p>
              <p style="font-size:.85rem;color:#5A6B52">USD por persona</p>
            </div>
          </div>
          <div class="photo-card__body">
            <p class="photo-card__title">Globo Aerostatico</p>
            <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.5rem;font-size:.88rem;color:#5A6B52">
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Vuelo al amanecer sobre el Serengeti
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                1 hora de vuelo aprox.
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Desayuno champagne al aterrizar
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Certificado de vuelo
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Vistas aereas de la migracion
              </li>
              <li style="display:flex;align-items:center;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Se puede anadir a cualquier paquete
              </li>
            </ul>
            <div style="margin-top:auto;padding-top:1rem">
              <a href="/contacto/" class="btn btn--primary" style="width:100%;justify-content:center">Reservar</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NOTAS IMPORTANTES -->
  <section class="section section--gray">
    <div class="container" style="max-width:800px">
      <div class="section__header">
        <h2>Informacion Importante</h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:1rem">
        <div style="background:white;border-radius:var(--radius-md);padding:1.5rem;box-shadow:var(--shadow-card)">
          <h3 style="font-size:1.1rem;margin-bottom:.5rem">Incluido en todos los paquetes</h3>
          <p style="font-size:.9rem;color:#5A6B52">Transporte en 4x4 Toyota Land Cruiser con techo abatible, guia profesional bilingue (espanol/ingles), entradas a parques nacionales, agua embotellada ilimitada y servicio de recogida en hotel/aeropuerto de Arusha.</p>
        </div>
        <div style="background:white;border-radius:var(--radius-md);padding:1.5rem;box-shadow:var(--shadow-card)">
          <h3 style="font-size:1.1rem;margin-bottom:.5rem">No incluido</h3>
          <p style="font-size:.9rem;color:#5A6B52">Vuelos internacionales, visa de Tanzania ($50 USD), seguro de viaje, propinas para guias y staff, bebidas alcoholicas, lavanderia y gastos personales.</p>
        </div>
        <div style="background:white;border-radius:var(--radius-md);padding:1.5rem;box-shadow:var(--shadow-card)">
          <h3 style="font-size:1.1rem;margin-bottom:.5rem">Politica de reservas</h3>
          <p style="font-size:.9rem;color:#5A6B52">Deposito del 30% para confirmar. Pago completo 30 dias antes del safari. Cancelacion gratuita hasta 60 dias antes. Cancelacion entre 30-60 dias: 50% de reembolso.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width:800px">
      <div class="section__header">
        <h2>Preguntas Frecuentes sobre Precios</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">{faq.question}</summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--green">
    <div class="container" style="text-align:center">
      <h2 style="color:white;margin-bottom:.75rem">Solicita tu Cotizacion Personalizada</h2>
      <p style="color:rgba(255,255,255,.85);margin-bottom:1.5rem;max-width:500px;margin-left:auto;margin-right:auto">Cada safari es unico. Cuentanos tus fechas y preferencias y te armamos un paquete a tu medida.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/contacto/" class="btn btn--amber btn--lg">Contactar</a>
        <a href="https://wa.me/255753000000?text=Hola,%20quiero%20una%20cotizacion%20de%20safari" class="btn btn--outline-white btn--lg" target="_blank" rel="noopener">WhatsApp</a>
      </div>
    </div>
  </section>
</BaseLayout>
