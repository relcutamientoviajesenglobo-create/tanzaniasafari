---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { place, faqPage } from '../../../i18n/schema';
import SafariTikTok from '../../../components/SafariTikTok.astro';
import PhotoGallery from '../../../components/PhotoGallery.astro';

const galleryImages = [
  { src: 'https://images.unsplash.com/photo-1436491865332-7a61a109db05?w=600&h=400&fit=crop&auto=format', alt: 'Aeropuerto Internacional del Kilimanjaro en Tanzania' },
  { src: 'https://images.unsplash.com/photo-1489392191049-fc10c97e64b6?w=600&h=400&fit=crop&auto=format', alt: 'Monte Kilimanjaro visto desde la sabana de Tanzania' },
  { src: 'https://images.unsplash.com/photo-1611348586804-61bf6c080437?w=600&h=400&fit=crop&auto=format', alt: 'Ciudad de Arusha con el Monte Meru de fondo' },
  { src: 'https://images.unsplash.com/photo-1523805009345-7448845a9e53?w=600&h=400&fit=crop&auto=format', alt: 'Vehículo 4x4 de traslado desde el aeropuerto a los parques' },
  { src: 'https://images.unsplash.com/photo-1516426122078-c23e76319801?w=600&h=400&fit=crop&auto=format', alt: 'Ruta terrestre hacia el Serengeti desde Arusha' },
  { src: 'https://images.unsplash.com/photo-1529074763233-c6fc62e6a0f0?w=600&h=400&fit=crop&auto=format', alt: 'Vista aérea de Dar es Salaam, Tanzania' },
];

const title = 'Como Llegar a Tanzania — Vuelos, Visados y Transporte 2026';
const description = 'Guia completa para llegar a Tanzania: vuelos al aeropuerto de Kilimanjaro (JRO), requisitos de visa, vacunas, transporte terrestre desde Arusha y consejos de viaje 2026.';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const breadcrumbs = [
  { label: 'Como Llegar' },
];

const faqs = [
  { question: 'Necesito visa para viajar a Tanzania?', answer: 'Si, la mayoria de nacionalidades requieren visa. Se puede obtener una e-Visa online por $50 USD (turismo) antes del viaje, o visa al llegar en el aeropuerto. El proceso online tarda 3-5 dias habiles.' },
  { question: 'Que vacunas necesito para Tanzania?', answer: 'La vacuna contra la fiebre amarilla es obligatoria si vienes de un pais endemico. Se recomienda hepatitis A y B, tifoidea y profilaxis contra malaria. Consulta a tu medico 6 semanas antes.' },
  { question: 'Cual es el mejor aeropuerto para llegar?', answer: 'El Aeropuerto Internacional del Kilimanjaro (JRO) es el mas conveniente, a 46 km de Arusha. El Aeropuerto Julius Nyerere (DAR) en Dar es Salaam es alternativa pero requiere vuelo interno adicional.' },
  { question: 'Ofrecen servicio de traslado desde el aeropuerto?', answer: 'Si, incluimos traslado desde el aeropuerto JRO a tu hotel en Arusha en todos nuestros paquetes. El trayecto dura aproximadamente 1 hora.' },
];

const schema = [
  place({
    name: 'Aeropuerto Internacional del Kilimanjaro',
    description,
    url: 'https://tanzaniasafari.info/como-llegar/',
  }),
  faqPage(faqs),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/como-llegar/"
  schema={schema}
  breadcrumbs={breadcrumbs}
>
  <Header slot="header" />
  <Footer slot="footer" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__acacia hero__acacia--tr" style="color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--green">Guia de Viaje</span>
        <h1 class="hero__title">Como Llegar a Tanzania</h1>
        <p class="hero__desc">Todo lo que necesitas saber para planificar tu viaje: vuelos, visados, vacunas y transporte terrestre. Llegamos a buscarte al aeropuerto.</p>
        <div class="hero__actions">
          <a href="/precios/" class="btn btn--primary btn--lg">Ver Paquetes</a>
          <a href="/contacto/" class="btn btn--outline btn--lg">Consultar</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img
            src="https://images.unsplash.com/photo-1489392191049-fc10c97e64b6?w=800&h=600&fit=crop&auto=format"
            alt="Monte Kilimanjaro visto desde la sabana de Tanzania"
            width="600"
            height="480"
            loading="eager"
          >
        </div>
      </div>
    </div>
  </section>

  <!-- VUELOS -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="chip chip--amber">Vuelos</span>
        <h2>Vuelos a Tanzania</h2>
        <p>Los dos aeropuertos internacionales principales de Tanzania ofrecen conexiones con las mayores aerolineas del mundo.</p>
      </div>

      <div class="card-grid card-grid--2">
        <div class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1436491865332-7a61a109db05?w=800&h=600&fit=crop&auto=format" alt="Aeropuerto Internacional del Kilimanjaro" width="400" height="300" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Recomendado</span>
            <p class="photo-card__title">Aeropuerto del Kilimanjaro (JRO)</p>
            <p style="font-size:.9rem;color:#5A6B52">El aeropuerto mas cercano a los parques del norte. A solo 46 km de Arusha (1 hora en coche). Vuelos directos desde Amsterdam (KLM), Estambul (Turkish Airlines), Nairobi y Addis Abeba.</p>
          </div>
        </div>

        <div class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1529074763233-c6fc62e6a0f0?w=800&h=600&fit=crop&auto=format" alt="Vista aerea de Dar es Salaam Tanzania" width="400" height="300" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Alternativa</span>
            <p class="photo-card__title">Julius Nyerere, Dar es Salaam (DAR)</p>
            <p style="font-size:.9rem;color:#5A6B52">El aeropuerto mas grande de Tanzania. Mas opciones de vuelos internacionales. Requiere vuelo interno a Arusha o Kilimanjaro (1.5 horas, desde $100 USD).</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VISADOS Y REQUISITOS -->
  <section class="section section--gray">
    <div class="container">
      <div class="section__header">
        <span class="chip chip--green">Requisitos</span>
        <h2>Visados y Documentacion</h2>
        <p>Informacion esencial sobre los requisitos de entrada a Tanzania para tu tranquilidad.</p>
      </div>

      <div class="service-cards" style="grid-template-columns: repeat(4, 1fr)">
        <div class="service-card">
          <p class="service-card__title">e-Visa</p>
          <p class="service-card__desc">Solicita tu visa online en immigration.go.tz. Costo: $50 USD. Procesamiento: 3-5 dias habiles. Validez: 90 dias.</p>
        </div>
        <div class="service-card">
          <p class="service-card__title">Pasaporte</p>
          <p class="service-card__desc">Pasaporte con validez minima de 6 meses desde la fecha de entrada y al menos 2 paginas en blanco.</p>
        </div>
        <div class="service-card">
          <p class="service-card__title">Vacunas</p>
          <p class="service-card__desc">Fiebre amarilla obligatoria si vienes de zona endemica. Recomendadas: hepatitis A/B, tifoidea, profilaxis malaria.</p>
        </div>
        <div class="service-card">
          <p class="service-card__title">Seguro de Viaje</p>
          <p class="service-card__desc">Altamente recomendado con cobertura medica y evacuacion. Tanzania no tiene sistema de salud publico para turistas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TRANSPORTE TERRESTRE -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="chip chip--amber">Transporte</span>
        <h2>Transporte Terrestre</h2>
        <p>Desde Arusha, la ciudad base para los safaris del norte, te llevamos a todos los parques nacionales.</p>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start">
        <div>
          <h3 style="margin-bottom:1rem">Desde Arusha a los Parques</h3>
          <div style="display:flex;flex-direction:column;gap:.75rem">
            <div style="background:white;border-radius:var(--radius-md);padding:1.25rem;box-shadow:var(--shadow-card);display:flex;justify-content:space-between;align-items:center">
              <div>
                <p style="font-weight:700;color:#2D4A22;font-size:.95rem">Tarangire</p>
                <p style="font-size:.8rem;color:#5A6B52">118 km desde Arusha</p>
              </div>
              <span style="font-family:var(--font-head);font-weight:800;color:#D4A017;font-size:1.1rem">~2h</span>
            </div>
            <div style="background:white;border-radius:var(--radius-md);padding:1.25rem;box-shadow:var(--shadow-card);display:flex;justify-content:space-between;align-items:center">
              <div>
                <p style="font-weight:700;color:#2D4A22;font-size:.95rem">Lago Manyara</p>
                <p style="font-size:.8rem;color:#5A6B52">126 km desde Arusha</p>
              </div>
              <span style="font-family:var(--font-head);font-weight:800;color:#D4A017;font-size:1.1rem">~2.5h</span>
            </div>
            <div style="background:white;border-radius:var(--radius-md);padding:1.25rem;box-shadow:var(--shadow-card);display:flex;justify-content:space-between;align-items:center">
              <div>
                <p style="font-weight:700;color:#2D4A22;font-size:.95rem">Ngorongoro</p>
                <p style="font-size:.8rem;color:#5A6B52">190 km desde Arusha</p>
              </div>
              <span style="font-family:var(--font-head);font-weight:800;color:#D4A017;font-size:1.1rem">~3.5h</span>
            </div>
            <div style="background:white;border-radius:var(--radius-md);padding:1.25rem;box-shadow:var(--shadow-card);display:flex;justify-content:space-between;align-items:center">
              <div>
                <p style="font-weight:700;color:#2D4A22;font-size:.95rem">Serengeti</p>
                <p style="font-size:.8rem;color:#5A6B52">335 km desde Arusha</p>
              </div>
              <span style="font-family:var(--font-head);font-weight:800;color:#D4A017;font-size:1.1rem">~7h</span>
            </div>
          </div>
        </div>
        <div>
          <h3 style="margin-bottom:1rem">Nuestro Servicio de Transporte</h3>
          <div style="background:white;border-radius:var(--radius-md);padding:1.5rem;box-shadow:var(--shadow-card)">
            <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.75rem;font-size:.9rem;color:#5A6B52">
              <li style="display:flex;align-items:flex-start;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E" style="flex-shrink:0;margin-top:3px"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Recogida en aeropuerto JRO incluida en todos los paquetes
              </li>
              <li style="display:flex;align-items:flex-start;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E" style="flex-shrink:0;margin-top:3px"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Vehiculos 4x4 Toyota Land Cruiser con techo abatible
              </li>
              <li style="display:flex;align-items:flex-start;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E" style="flex-shrink:0;margin-top:3px"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Conductores-guias con mas de 10 anos de experiencia
              </li>
              <li style="display:flex;align-items:flex-start;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E" style="flex-shrink:0;margin-top:3px"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Vehiculos equipados con radio, nevera y enchufes USB
              </li>
              <li style="display:flex;align-items:flex-start;gap:.5rem">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#3D6B2E" style="flex-shrink:0;margin-top:3px"><path d="M10 0a10 10 0 100 20 10 10 0 000-20zm4.3 7.3l-5 5a1 1 0 01-1.4 0l-2-2a1 1 0 111.4-1.4L8.6 10l4.3-4.3a1 1 0 111.4 1.4z"/></svg>
                Maximo 6 pasajeros por vehiculo para confort
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--gray">
    <div class="container" style="max-width:800px">
      <div class="section__header">
        <h2>Preguntas Frecuentes</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">{faq.question}</summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- TIKTOK & GALLERY -->
  <SafariTikTok category="general" lang="es" />
  <PhotoGallery images={galleryImages} title="Galería: Llegar a Tanzania" />

  <!-- CTA -->
  <section class="section section--green">
    <div class="container" style="text-align:center">
      <h2 style="color:white;margin-bottom:.75rem">Planifica tu Viaje a Tanzania</h2>
      <p style="color:rgba(255,255,255,.85);margin-bottom:1.5rem;max-width:500px;margin-left:auto;margin-right:auto">Te ayudamos con toda la logistica. Traslados, alojamiento y safari todo organizado para ti.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/precios/" class="btn btn--amber btn--lg">Ver Precios</a>
        <a href="/contacto/" class="btn btn--outline-white btn--lg">Contactar</a>
      </div>
    </div>
  </section>
</BaseLayout>
