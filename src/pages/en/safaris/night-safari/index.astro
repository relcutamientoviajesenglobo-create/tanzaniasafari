---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import { touristAttraction, faqPage } from '../../../../i18n/schema';

const lang = 'en';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const faqItems = [
  { question: 'What is a night safari in Tanzania?', answer: 'A night safari is a guided game drive conducted <strong>after sunset</strong>, typically from 6:30 PM to 10:00 PM. Using powerful spotlights and infrared equipment, your guide reveals the hidden world of nocturnal wildlife: hunting predators, foraging aardvarks, bush babies, porcupines and many species that are impossible to see during daylight hours.' },
  { question: 'Where do night safaris take place?', answer: 'Night safaris operate in specific conservation areas where nighttime driving is permitted. The most popular locations include <strong>Lake Manyara National Park</strong>, <strong>Tarangire</strong> and private conservancies bordering the Serengeti. National park regulations restrict night driving in the Serengeti and Ngorongoro, so we use approved areas that offer excellent nocturnal wildlife viewing.' },
  { question: 'Is a night safari safe?', answer: 'Absolutely. Night safaris are conducted in the same reinforced 4x4 vehicles used for daytime drives. Your guide is trained in nocturnal wildlife behavior and carries <strong>satellite communication</strong> equipment. The spotlight does not disturb animals (they are accustomed to it), and you remain safely inside the vehicle at all times. Our guides carry first aid kits and have emergency protocols in place.' },
  { question: 'What animals can I see on a night safari?', answer: 'Night safaris reveal species rarely seen during the day: <strong>leopards on the hunt</strong>, spotted hyenas, bat-eared foxes, aardvarks, aardwolves, bush babies (galagos), civets, genets, porcupines, spring hares and many owl species. Predators are significantly more active after dark, making night drives some of the most thrilling wildlife encounters in Africa.' },
  { question: 'Can I photograph wildlife on a night safari?', answer: 'Yes, but it requires specific techniques. Flash photography is generally discouraged as it can startle animals. However, our guides use <strong>red-filter spotlights</strong> that are wildlife-friendly and suitable for photography. We recommend cameras that perform well at high ISO settings (ISO 3200+). For the best results, combine a night safari with a <a href="/en/safaris/photo-safari/" style="color:#3D6B2E;font-weight:700">photo safari</a> for daytime shots.' },
  { question: 'How long does a night safari last?', answer: 'A typical night game drive lasts <strong>3 to 4 hours</strong>, departing around sunset (6:00-6:30 PM) and returning by 9:30-10:00 PM. The drive includes a brief stop for hot beverages and stargazing in a safe area. Night safaris can be added to any multi-day <a href="/en/safaris/classic-safari/" style="color:#3D6B2E;font-weight:700">classic safari</a> itinerary.' },
];

const schema = [
  touristAttraction({
    name: 'Night Safari in Tanzania',
    description: 'Experience nocturnal wildlife in the Serengeti and Tanzania conservation areas. Spot leopards, hyenas, bush babies and more with expert guides after dark.',
    url: 'https://safaritanzania.info/en/safaris/night-safari/',
  }),
  faqPage(faqItems),
];
---

<BaseLayout
  title="Night Safari in Tanzania — Nocturnal Wildlife in the Serengeti"
  description="Experience the African bush after dark on a guided night safari. Spot leopards hunting, hyenas, bush babies, aardvarks and nocturnal predators with expert guides and specialized equipment."
  lang={lang}
  schema={schema}
  breadcrumbs={[
    { label: 'Safaris', href: '/en/safaris/' },
    { label: 'Night Safari' },
  ]}
>
  <Header slot="header" lang={lang} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__acacia hero__acacia--tr" style="color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container">
      <div class="hero__inner">
        <div class="hero__text">
          <span class="chip chip--green">After Dark</span>
          <h1 class="hero__title">Night Safari in Tanzania</h1>
          <p class="hero__desc">When the sun sets, the real drama begins. Discover the hidden world of nocturnal predators, elusive creatures and the haunting sounds of the African bush under a canopy of stars.</p>
          <div class="hero__actions">
            <a href="/en/prices/" class="btn btn--primary btn--lg">See prices 2026</a>
            <a href="/en/contact/" class="btn btn--outline btn--lg">Book night safari</a>
          </div>
          <div class="stats-row">
            <div class="stat"><strong>3-4 hrs</strong><span>Sunset to night</span></div>
            <div class="stat"><strong>20+</strong><span>Nocturnal species</span></div>
            <div class="stat"><strong>Expert</strong><span>Trained guides</span></div>
          </div>
        </div>
        <div class="hero__visual">
          <div class="hero__photo-frame">
            <div class="hero__deco hero__deco--tr"></div>
            <img
              src="https://images.unsplash.com/photo-1456926631375-92c8ce872def?w=800&h=640&fit=crop&auto=format"
              alt="Leopard spotted during a nocturnal game drive in Tanzania"
              width="800" height="640" loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE EXPERIENCE -->
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--amber">The Experience</span>
        <h2>What happens after sunset</h2>
        <p>As twilight fades and the stars emerge, an entirely different cast of characters takes the stage on the Tanzanian plains.</p>
      </div>
      <div class="card-grid card-grid--2 animate-on-scroll delay-1">
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1456926631375-92c8ce872def?w=600&h=450&fit=crop&auto=format" alt="Leopard in low-light conditions during a night game drive" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <h3 class="photo-card__title">Predators on the Hunt</h3>
            <p>Night is when Africa's top predators are most active. Watch leopards stalk through the undergrowth, spotted hyenas coordinate their hunts and serval cats pounce on prey with incredible precision. The spotlight reveals behaviors rarely witnessed during daylight hours.</p>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1516426122078-c23e76319801?w=600&h=450&fit=crop&auto=format" alt="African savanna under starry night sky with silhouetted acacia trees" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <h3 class="photo-card__title">Stargazing & Night Sounds</h3>
            <p>Between wildlife sightings, your guide stops the vehicle in a safe area for hot beverages and stargazing. Without light pollution, Tanzania's night sky is extraordinary: the Milky Way, Southern Cross and shooting stars create a celestial spectacle while the bush serenades you with hyena calls and owl hoots.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NOCTURNAL WILDLIFE -->
  <section class="section section--green bg-green" style="position:relative;overflow:hidden">
    <div style="position:absolute;bottom:0;left:-30px;opacity:.08;pointer-events:none;color:#D4A017;transform:rotate(180deg)">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--amber">Nocturnal Wildlife</span>
        <h2>Creatures of the night</h2>
        <p>Night safaris reveal an entirely different world of animals that sleep during the day and come alive under the cover of darkness.</p>
      </div>
      <div class="service-cards animate-on-scroll delay-1">
        <div class="service-card">
          <h3 class="service-card__title">Leopard</h3>
          <p class="service-card__desc">The most elusive of the Big Five, leopards are primarily nocturnal hunters. Watch them stalk prey with stealth and power, or rest on acacia branches under the moonlight.</p>
        </div>
        <div class="service-card">
          <h3 class="service-card__title">Bush Baby (Galago)</h3>
          <p class="service-card__desc">These tiny primates with enormous eyes leap between branches at incredible speed. Their haunting calls echo through the African night, earning them the name "bush babies."</p>
        </div>
        <div class="service-card">
          <h3 class="service-card__title">Spotted Hyena</h3>
          <p class="service-card__desc">Highly intelligent pack hunters, hyenas are most active after dark. Witness their complex social dynamics, eerie vocalizations and remarkable hunting strategies.</p>
        </div>
        <div class="service-card">
          <h3 class="service-card__title">Aardvark</h3>
          <p class="service-card__desc">One of Africa's most elusive creatures, the aardvark emerges only at night to feed on termites. Seeing one is a rare privilege that makes any night safari unforgettable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--green">What is Included</span>
        <h2>Night safari package details</h2>
        <p>Everything you need for a safe and extraordinary nocturnal wildlife experience.</p>
      </div>
      <div class="card-grid card-grid--3 animate-on-scroll delay-1">
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__body">
            <h3 class="photo-card__title">Equipment Provided</h3>
            <p>High-powered spotlights with red filters (wildlife-friendly), blankets for the cooler evening air, hot beverages (coffee, tea, hot chocolate) and night-vision binoculars on premium tours.</p>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__body">
            <h3 class="photo-card__title">Safety Measures</h3>
            <p>Reinforced 4x4 vehicles, satellite phone communication, experienced night-certified guide, first aid kit, emergency protocols and constant contact with base camp or lodge.</p>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__body">
            <h3 class="photo-card__title">The Schedule</h3>
            <p>Depart at sunset (approximately 6:00 PM). Three to four hours of game driving with a stargazing break. Return to camp or lodge by 9:30-10:00 PM. Light dinner can be arranged.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMBINE WITH -->
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--amber">Combine Your Experience</span>
        <h2>Add a night safari to your trip</h2>
        <p>Night safaris pair perfectly with our other safari experiences for a complete 24-hour wildlife adventure.</p>
      </div>
      <div class="card-grid card-grid--2 animate-on-scroll delay-1">
        <a href="/en/safaris/classic-safari/" class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1523805009345-7448845a9e53?w=600&h=450&fit=crop&auto=format" alt="Classic safari game drive vehicle in the Serengeti" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <h3 class="photo-card__title">Classic Safari + Night Drive</h3>
            <p>Combine daytime game drives with an evening night safari for a complete 24-hour wildlife experience. See the Big Five by day and nocturnal predators by night.</p>
            <span class="photo-card__arrow"><svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 4 13 10 7 16"/></svg></span>
          </div>
        </a>
        <a href="/en/safaris/photo-safari/" class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1546182990-dffeafbe841d?w=600&h=450&fit=crop&auto=format" alt="Lion in dramatic lighting for photography safari" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <h3 class="photo-card__title">Photo Safari + Night Drive</h3>
            <p>Capture golden hour images by day and attempt challenging low-light photography at night. Perfect for photographers seeking the full range of African wildlife imagery.</p>
            <span class="photo-card__arrow"><svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 4 13 10 7 16"/></svg></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--green">FAQ</span>
        <h2>Night safari questions</h2>
        <p>Everything you need to know about our nocturnal wildlife experiences in Tanzania.</p>
      </div>
      <div class="faq-list animate-on-scroll delay-1">
        {faqItems.map(item => (
          <details>
            <summary>{item.question}</summary>
            <div class="faq-answer" set:html={item.answer} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--green bg-green" style="text-align:center;position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.1;pointer-events:none;color:#D4A017">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Experience the African night</h2>
        <p>Discover the hidden world of nocturnal wildlife with our expert night safari guides. An unforgettable addition to any Tanzania trip.</p>
      </div>
      <div class="animate-on-scroll delay-1" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/en/prices/" class="btn btn--primary btn--lg">See prices 2026</a>
        <a href="/en/contact/" class="btn btn--outline btn--lg" style="border-color:white;color:white">Book night safari</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</BaseLayout>
