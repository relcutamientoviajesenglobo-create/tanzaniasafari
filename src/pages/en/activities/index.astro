---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { touristAttraction, faqPage } from '../../../i18n/schema';

const lang = 'en';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const faqItems = [
  { question: 'What activities are available besides game drives?', answer: 'Tanzania offers a wide range of activities beyond traditional safaris: <a href="/en/activities/wildlife-watching/" style="color:#3D6B2E;font-weight:700">wildlife watching</a> including the Great Migration, <a href="/en/activities/bush-walks/" style="color:#3D6B2E;font-weight:700">bush walks</a> with Masai guides, <a href="/en/activities/hot-air-balloon/" style="color:#3D6B2E;font-weight:700">hot air balloon</a> flights over the Serengeti, cultural village visits, bird watching, crater lake visits and stargazing experiences.' },
  { question: 'Are activities suitable for all fitness levels?', answer: 'Most activities accommodate various fitness levels. <strong>Wildlife watching</strong> from vehicles requires no physical effort. <strong>Bush walks</strong> range from gentle strolls to moderate hikes (2-4 hours). <strong>Balloon flights</strong> require basic mobility to board the basket. Our team can recommend the best activities for your fitness level and any mobility considerations.' },
  { question: 'Can I combine multiple activities in one trip?', answer: 'Absolutely! Many of our guests combine game drives with bush walks, a balloon flight and cultural experiences. A typical <strong>5-day safari</strong> can include 2-3 different activities alongside traditional game drives. Contact us to design a custom itinerary that includes your preferred activities at the best <a href="/en/prices/" style="color:#3D6B2E;font-weight:700">prices</a>.' },
  { question: 'What should I wear for outdoor activities?', answer: 'Wear lightweight, breathable clothing in <strong>neutral earth tones</strong> (khaki, olive, brown, tan). Avoid bright white, blue and black clothing. Sturdy closed-toe shoes are essential for bush walks. A hat, sunglasses and sunscreen (SPF 50+) are necessary for all outdoor activities. Layering is recommended as mornings can be cool.' },
  { question: 'Are children allowed on all activities?', answer: 'Most activities welcome children with some age restrictions. <strong>Wildlife watching</strong> from vehicles has no age limit. <strong>Bush walks</strong> typically require children to be at least 12 years old. <strong>Hot air balloon</strong> flights have a minimum age of 7 years. Children under 5 are free on most vehicle-based activities. See our <a href="/en/prices/" style="color:#3D6B2E;font-weight:700">prices page</a> for family packages.' },
];

const schema = [
  touristAttraction({
    name: 'Activities in Tanzania — Wildlife Watching, Bush Walks, Balloon & More',
    description: 'Discover the best activities in Tanzania beyond traditional safaris. Wildlife watching, bush walks with Masai guides, hot air balloon flights and more.',
    url: 'https://safaritanzania.info/en/activities/',
  }),
  faqPage(faqItems),
];
---

<BaseLayout
  title="Activities in Tanzania — Wildlife Watching, Bush Walks, Balloon & More"
  description="Discover extraordinary activities in Tanzania beyond game drives. Wildlife watching, bush walks with Masai guides, hot air balloon flights over the Serengeti and cultural experiences."
  lang={lang}
  schema={schema}
  breadcrumbs={[{ label: 'Activities' }]}
>
  <Header slot="header" lang={lang} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero__acacia hero__acacia--tr" style="color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container">
      <div class="hero__inner">
        <div class="hero__text">
          <span class="chip chip--green">Beyond Game Drives</span>
          <h1 class="hero__title">Activities &amp; experiences in Tanzania</h1>
          <p class="hero__desc">Tanzania offers far more than traditional safaris. Walk through the bush with Masai warriors, float over the Serengeti at dawn, track the Great Migration and immerse yourself in authentic African culture.</p>
          <div class="hero__actions">
            <a href="/en/prices/" class="btn btn--primary btn--lg">See prices 2026</a>
            <a href="/en/safaris/" class="btn btn--outline btn--lg">View safaris</a>
          </div>
        </div>
        <div class="hero__visual">
          <div class="hero__photo-frame">
            <div class="hero__deco hero__deco--tr"></div>
            <img
              src="https://images.unsplash.com/photo-1504598318550-17eba1008a68?w=800&h=640&fit=crop&auto=format"
              alt="Hot air balloon floating over the Serengeti savanna at sunrise"
              width="800" height="640" loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ACTIVITY CARDS -->
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--amber">Choose Your Adventure</span>
        <h2>Our featured activities</h2>
        <p>Each activity offers a unique perspective on Tanzania's wildlife, landscapes and culture. Mix and match to create your perfect adventure.</p>
      </div>
      <div class="card-grid card-grid--3 animate-on-scroll delay-1">
        <a href="/en/activities/wildlife-watching/" class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1574068468547-40d0e2fba56c?w=600&h=450&fit=crop&auto=format" alt="Wildebeest herd during the Great Migration in the Serengeti" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Wildlife</span>
            <h3 class="photo-card__title">Wildlife Watching</h3>
            <p>Track the Big Five, witness the Great Migration and observe Africa's most iconic animals in their natural habitat. Expert guides interpret animal behavior and ecology.</p>
            <span class="photo-card__arrow"><svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 4 13 10 7 16"/></svg></span>
          </div>
        </a>
        <a href="/en/activities/bush-walks/" class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1489392191049-fc10c97e64b6?w=600&h=450&fit=crop&auto=format" alt="Masai guide leading a walking safari through the African bush" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Adventure</span>
            <h3 class="photo-card__title">Bush Walks</h3>
            <p>Step out of the vehicle and walk through the savanna with experienced Masai guides. Learn tracking skills, discover medicinal plants and connect with the landscape at ground level.</p>
            <span class="photo-card__arrow"><svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 4 13 10 7 16"/></svg></span>
          </div>
        </a>
        <a href="/en/activities/hot-air-balloon/" class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1504598318550-17eba1008a68?w=600&h=450&fit=crop&auto=format" alt="Hot air balloon safari over the Serengeti National Park at dawn" width="600" height="450" loading="lazy" />
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Aerial</span>
            <h3 class="photo-card__title">Hot Air Balloon</h3>
            <p>Soar over the Serengeti at dawn for a breathtaking aerial perspective. Float silently above herds of wildlife and land for a champagne bush breakfast.</p>
            <span class="photo-card__arrow"><svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 4 13 10 7 16"/></svg></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- MORE EXPERIENCES -->
  <section class="section section--green bg-green" style="position:relative;overflow:hidden">
    <div style="position:absolute;top:20px;right:-30px;opacity:.08;pointer-events:none;color:#D4A017">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--amber">Cultural & Nature Experiences</span>
        <h2>More ways to experience Tanzania</h2>
        <p>Complement your safari with these authentic cultural and nature experiences that reveal the heart and soul of East Africa.</p>
      </div>
      <div class="service-cards animate-on-scroll delay-1">
        <div class="service-card">
          <div class="service-card__icon">
            <svg viewBox="0 0 48 48" fill="currentColor"><path d="M24 4C12.95 4 4 12.95 4 24s8.95 20 20 20 20-8.95 20-20S35.05 4 24 4zm0 6c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6 2.69-6 6-6zm0 28.4c-5 0-9.27-2.88-11.34-7.07C15.07 28.55 20 27 24 27c3.99 0 8.93 1.55 11.34 4.33C33.27 35.52 29 38.4 24 38.4z"/></svg>
          </div>
          <h3 class="service-card__title">Masai Village Visit</h3>
          <p class="service-card__desc">Visit an authentic Masai boma (village) and learn about their traditions, beadwork, warrior culture and harmonious relationship with wildlife. An enriching cultural exchange.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg viewBox="0 0 48 48" fill="currentColor"><path d="M18.85 10.39l1.06-3.54c.18-.63.76-1.06 1.42-1.06h5.34c.66 0 1.24.43 1.42 1.06l1.06 3.54 3.54 1.06c.63.18 1.06.76 1.06 1.42v5.34c0 .66-.43 1.24-1.06 1.42L29.15 20 28.09 23.54c-.18.63-.76 1.06-1.42 1.06H21.33c-.66 0-1.24-.43-1.42-1.06L18.85 20l-3.54-1.06c-.63-.18-1.06-.76-1.06-1.42v-5.34c0-.66.43-1.24 1.06-1.42l3.54-1.37z M24 28c-7.73 0-14 6.27-14 14h28c0-7.73-6.27-14-14-14z"/></svg>
          </div>
          <h3 class="service-card__title">Bird Watching</h3>
          <p class="service-card__desc">Tanzania hosts over 1,100 bird species. Specialized birding excursions target flamingo colonies, eagles, kingfishers, hornbills and the spectacular lilac-breasted roller.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg viewBox="0 0 48 48" fill="currentColor"><path d="M24 2C13.51 2 5 10.51 5 21c0 14.28 17.2 24.26 17.93 24.67.31.18.69.18 1 0C24.8 45.26 43 35.28 43 21 43 10.51 34.49 2 24 2zm0 27c-4.97 0-9-4.03-9-9s4.03-9 9-9 9 4.03 9 9-4.03 9-9 9z"/></svg>
          </div>
          <h3 class="service-card__title">Crater Lake Excursion</h3>
          <p class="service-card__desc">Visit the stunning Empakaai Crater or Lake Natron to see flamingos, volcanic landscapes and dramatic scenery that few tourists ever experience.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">
            <svg viewBox="0 0 48 48" fill="currentColor"><path d="M14 36l12-4 12 4V8c0-1.1-.9-2-2-2H14c-1.1 0-2 .9-2 2v28zM38 6c1.1 0 2 .9 2 2v36l-16-6-16 6V8c0-1.1.9-2 2-2h28z"/></svg>
          </div>
          <h3 class="service-card__title">Stargazing</h3>
          <p class="service-card__desc">Far from city lights, Tanzania's night skies are among the best on Earth. Our guides lead stargazing sessions identifying constellations, planets and the Milky Way band.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PLANNING -->
  <section class="section section--gray">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--green">Plan Your Activities</span>
        <h2>How to include activities in your trip</h2>
        <p>Activities can be added to any safari package. Here is how to get started.</p>
      </div>
      <div class="card-grid card-grid--3 animate-on-scroll delay-1">
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__body">
            <h3 class="photo-card__title">1. Choose your safari</h3>
            <p>Start with a <a href="/en/safaris/classic-safari/" style="color:#3D6B2E;font-weight:700">classic</a>, <a href="/en/safaris/photo-safari/" style="color:#3D6B2E;font-weight:700">photo</a> or <a href="/en/safaris/night-safari/" style="color:#3D6B2E;font-weight:700">night safari</a> as your base experience. Activities are added as complements to your core safari itinerary.</p>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__body">
            <h3 class="photo-card__title">2. Select activities</h3>
            <p>Pick from wildlife watching, bush walks, balloon flights, cultural visits or birding. Our team will recommend the best combination based on your interests and schedule.</p>
          </div>
        </div>
        <div class="photo-card" style="cursor:default">
          <div class="photo-card__body">
            <h3 class="photo-card__title">3. Contact us</h3>
            <p>Reach out via <a href="/en/contact/" style="color:#3D6B2E;font-weight:700">our contact page</a> or WhatsApp and we will design a custom itinerary with your preferred activities at the best available prices.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <span class="chip chip--green">FAQ</span>
        <h2>Activity questions answered</h2>
        <p>Common questions about activities and experiences in Tanzania.</p>
      </div>
      <div class="faq-list animate-on-scroll delay-1">
        {faqItems.map(item => (
          <details>
            <summary>{item.question}</summary>
            <div class="faq-answer" set:html={item.answer} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--green bg-green" style="text-align:center;position:relative;overflow:hidden">
    <div style="position:absolute;top:0;right:0;opacity:.1;pointer-events:none;color:#D4A017">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Ready for adventure?</h2>
        <p>Discover Tanzania's extraordinary activities and create memories that will last a lifetime.</p>
      </div>
      <div class="animate-on-scroll delay-1" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/en/prices/" class="btn btn--primary btn--lg">See prices 2026</a>
        <a href="/en/contact/" class="btn btn--outline btn--lg" style="border-color:white;color:white">Plan my trip</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</BaseLayout>
