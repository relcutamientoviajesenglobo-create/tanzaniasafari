---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import SafariTikTok from '../../../components/SafariTikTok.astro';
import PhotoGallery from '../../../components/PhotoGallery.astro';

const lang = 'en';
const title = 'Safari Camps in Tanzania — Authentic Bush Camp Experience';

const galleryImages = [
  { src: 'https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=600&h=400&fit=crop&auto=format', alt: 'Luxury tented camp at sunset with canvas tent under acacia trees in the Serengeti' },
  { src: 'https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=600&h=400&fit=crop&auto=format', alt: 'Mobile migration camp with green canvas tents set on the Serengeti plains' },
  { src: 'https://images.unsplash.com/photo-1445019980597-93fa8acb246c?w=600&h=400&fit=crop&auto=format', alt: 'Permanent tented camp with wooden deck and panoramic bush views' },
  { src: 'https://images.unsplash.com/photo-1510312305653-8ed496efae75?w=600&h=400&fit=crop&auto=format', alt: 'Fly camp setup under the Milky Way with minimal lighting in the wilderness' },
  { src: 'https://images.unsplash.com/photo-1516426122078-c23e76319801?w=600&h=400&fit=crop&auto=format', alt: 'Bush dinner setup at a tented camp under the stars in Tanzania' },
  { src: 'https://images.unsplash.com/photo-1523805009345-7448845a9e53?w=600&h=400&fit=crop&auto=format', alt: 'Game drive departing from a tented camp at dawn in the Serengeti' },
];
const description = 'Experience authentic tented safari camps in Tanzania. Sleep under canvas in the Serengeti, Ngorongoro, and Tarangire with close-to-nature luxury, bush dinners, and unforgettable wildlife encounters.';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const breadcrumbs = [
  { label: 'Lodging', href: '/lodging/' },
  { label: 'Safari Camps' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description: description,
  url: 'https://safaritanzania.info/lodging/camps/',
};
---

<BaseLayout title={title} description={description} schema={schema} breadcrumbs={breadcrumbs} lang={lang}>
  <Header slot="header" lang={lang} />
  <Footer slot="footer" lang={lang} />

  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--green">Bush Experience</span>
        <h1>Safari Camps in Tanzania</h1>
        <p>Fall asleep to the symphony of the African night and wake to birdsong at dawn. Tanzania's tented camps offer an authentic, immersive safari experience that connects you directly with the wild while maintaining thoughtful comfort.</p>
        <div class="hero__actions">
          <a href="/prices/" class="btn btn--primary btn--lg">See 2026 Prices</a>
          <a href="/lodging/lodges/" class="btn btn--outline btn--lg">View Safari Lodges</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img
            src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=600&h=400&fit=crop"
            alt="Luxury tented camp at sunset with canvas tent under acacia trees in the Serengeti"
            width="600"
            height="400"
            loading="eager"
            style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit"
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Camp Types -->
  <section class="section section--gray">
    <div class="container">
      <h2 style="text-align:center;margin-bottom:.75rem">Types of Safari Camps</h2>
      <p style="text-align:center;max-width:620px;margin:0 auto 3rem">From mobile camps that follow the Great Migration to permanent tented lodges with full amenities, choose the level of adventure that suits you.</p>

      <div class="card-grid card-grid--3" style="grid-template-columns:repeat(auto-fit,minmax(300px,1fr))">
        <div class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=400&h=300&fit=crop" alt="Mobile tented camp with green canvas tents in the Serengeti" width="400" height="300" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Seasonal</span>
            <p class="photo-card__title">Mobile Migration Camps</p>
            <p style="font-size:.9rem;color:var(--mc-text-muted)">These camps relocate throughout the year to follow the wildebeest migration across the Serengeti. Intimate settings with 6-10 tents and exclusive game-viewing areas.</p>
          </div>
        </div>
        <div class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1445019980597-93fa8acb246c?w=400&h=300&fit=crop" alt="Permanent luxury tented camp with wooden decks" width="400" height="300" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Year-Round</span>
            <p class="photo-card__title">Permanent Tented Camps</p>
            <p style="font-size:.9rem;color:var(--mc-text-muted)">Fixed-location camps with raised wooden platforms, en-suite bathrooms, and electricity. All the charm of canvas living with the reliability of permanent infrastructure.</p>
          </div>
        </div>
        <div class="photo-card">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1510312305653-8ed496efae75?w=400&h=300&fit=crop" alt="Fly camp with minimal setup under the Milky Way" width="400" height="300" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Adventure</span>
            <p class="photo-card__title">Fly Camps & Bush Camps</p>
            <p style="font-size:.9rem;color:var(--mc-text-muted)">Stripped-back camping for the true adventurer. Lightweight setups in remote locations with camp cook, guide, and uninterrupted views of the African night sky.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Camp Experience -->
  <section class="section">
    <div class="container">
      <h2 style="text-align:center;margin-bottom:.75rem">The Camp Experience</h2>
      <p style="text-align:center;max-width:620px;margin:0 auto 3rem">Life at a tented camp follows the rhythm of the bush. Here is what a typical day looks like.</p>

      <div class="card-grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem">
        <div style="display:flex;gap:1rem;align-items:flex-start">
          <span style="font-size:1.8rem;flex-shrink:0">🌅</span>
          <div>
            <h3 style="font-size:1.1rem;margin-bottom:.35rem">Dawn Game Drive</h3>
            <p style="font-size:.92rem">Wake at 5:30 AM with a hot coffee delivered to your tent. Head out on the morning game drive when predators are most active and the light is magical.</p>
          </div>
        </div>
        <div style="display:flex;gap:1rem;align-items:flex-start">
          <span style="font-size:1.8rem;flex-shrink:0">☀️</span>
          <div>
            <h3 style="font-size:1.1rem;margin-bottom:.35rem">Midday Rest</h3>
            <p style="font-size:.92rem">Return for a hearty brunch, then relax during the hottest hours. Read a book, nap to the sounds of nature, or enjoy a siesta in a hammock under the shade.</p>
          </div>
        </div>
        <div style="display:flex;gap:1rem;align-items:flex-start">
          <span style="font-size:1.8rem;flex-shrink:0">🌇</span>
          <div>
            <h3 style="font-size:1.1rem;margin-bottom:.35rem">Sundowner & Night</h3>
            <p style="font-size:.92rem">Afternoon game drive followed by sundowner drinks overlooking the plains. Return to camp for a bush dinner under the stars, accompanied by the sounds of the savanna.</p>
          </div>
        </div>
        <div style="display:flex;gap:1rem;align-items:flex-start">
          <span style="font-size:1.8rem;flex-shrink:0">🔥</span>
          <div>
            <h3 style="font-size:1.1rem;margin-bottom:.35rem">Campfire Stories</h3>
            <p style="font-size:.92rem">End each evening around the campfire sharing stories with fellow travelers and your guides. The perfect setting for spotting shooting stars and listening to hyenas call.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <PhotoGallery images={galleryImages} title="Tented Camps Gallery" />
  <SafariTikTok category="lodges" lang="en" />

  <!-- CTA -->
  <section class="section section--green">
    <div class="container" style="text-align:center;position:relative">
      <div style="position:absolute;top:-30px;right:0;opacity:.12;pointer-events:none;color:#D4A017">
        <Fragment set:html={ACACIA_LARGE} />
      </div>
      <h2 style="color:white;margin-bottom:.75rem">Book Your Camp Adventure</h2>
      <p style="color:rgba(255,255,255,.85);margin-bottom:1.5rem;max-width:520px;margin-left:auto;margin-right:auto">Experience the authentic African bush at our carefully selected tented camps. Contact us to design your ideal safari itinerary.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/prices/" class="btn btn--primary btn--lg">See 2026 Prices</a>
        <a href="/contact/" class="btn btn--outline-white btn--lg" style="border-color:white;color:white">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
