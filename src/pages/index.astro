---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VideoGallery from '../components/VideoGallery.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": ["TouristAttraction", "LocalBusiness"],
    "name": "Safari Tanzania",
    "description": "Safari Tanzania ofrece expediciones de vida salvaje en el Serengeti, Ngorongoro y Tarangire. Avistamiento de los Big Five, Gran Migración, globo aerostático y caminatas bush con guías Masái.",
    "url": "https://safaritanzania.info",
    "telephone": "+255753000000",
    "email": "info@safaritanzania.info",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Sokoine Road",
      "addressLocality": "Arusha",
      "addressRegion": "Arusha Region",
      "addressCountry": "TZ"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": -3.3869, "longitude": 36.6830 },
    "openingHoursSpecification": [{
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "06:00", "closes": "18:00"
    }],
    "priceRange": "$$$",
    "sameAs": ["https://www.facebook.com/safaritanzaniainfo", "https://www.instagram.com/safaritanzaniainfo", "https://www.tiktok.com/@safaritanzaniainfo", "https://www.pinterest.com/safaritanzaniainfo"]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta un safari en Tanzania?",
        "acceptedAnswer": { "@type": "Answer", "text": "Un safari de 4 días en Tanzania cuesta desde $1,800 USD por persona en temporada baja, incluyendo alojamiento en lodge, transporte en 4x4, guía profesional y comidas completas. Los precios varían según la temporada y el tipo de alojamiento elegido." }
      },
      {
        "@type": "Question",
        "name": "¿Cuál es la mejor época para un safari en Tanzania?",
        "acceptedAnswer": { "@type": "Answer", "text": "La mejor época depende de lo que busques. De junio a octubre es temporada seca ideal para avistamiento general. De enero a marzo hay crías recién nacidas en el Serengeti. La Gran Migración cruza el río Mara entre julio y septiembre." }
      },
      {
        "@type": "Question",
        "name": "¿Se pueden ver los Big Five en Tanzania?",
        "acceptedAnswer": { "@type": "Answer", "text": "Sí. Tanzania es uno de los mejores destinos del mundo para ver los Big Five: león, leopardo, elefante, rinoceronte y búfalo. El Cráter del Ngorongoro es el lugar con mayor probabilidad de verlos todos en un solo día." }
      },
      {
        "@type": "Question",
        "name": "¿Qué vacunas necesito para ir a Tanzania?",
        "acceptedAnswer": { "@type": "Answer", "text": "Se requiere vacuna de fiebre amarilla para ingresar a Tanzania. Se recomiendan también hepatitis A y B, fiebre tifoidea y profilaxis antimalárica. Consulta con tu médico al menos 6 semanas antes del viaje." }
      },
      {
        "@type": "Question",
        "name": "¿Tanzania es un destino seguro para turistas?",
        "acceptedAnswer": { "@type": "Answer", "text": "Sí. Tanzania es considerado uno de los países más seguros de África oriental para turismo. Los parques nacionales cuentan con rangers y guías certificados. Se recomienda viajar con operadores registrados como Safari Tanzania." }
      }
    ]
  }
];

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;
---

<BaseLayout
  title="Safari Tanzania — Safaris de Vida Salvaje en el Serengeti y Ngorongoro 2026"
  description="Safari Tanzania: expediciones de vida salvaje en el Serengeti, Ngorongoro y Tarangire. Big Five, Gran Migración, globo aerostático y caminatas bush. Precios y reservas 2026."
  canonical="/"
  schema={schema}
>
  <Header slot="header" />
  <Footer slot="footer" />

  <!-- ============================================================
       PRICE BANNER — Barra informativa debajo del header
  ============================================================ -->
  <div class="price-banner" aria-label="Información de safaris 2026">
    <div class="container price-banner__inner">
      <div class="price-banner__items">
        <span class="price-banner__item">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M15 1H9v2h6V1zm-4 13h2V8h-2v6zm8.03-6.61l1.42-1.42c-.43-.51-.9-.99-1.41-1.41l-1.42 1.42A8.962 8.962 0 0012 4c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-2.12-.74-4.07-1.97-5.61zM12 20c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/></svg>
          Safaris <strong>todo el año</strong>
        </span>
        <span class="price-banner__divider" aria-hidden="true"></span>
        <span class="price-banner__item">
          Desde <strong class="price-banner__price">$1,800 USD</strong>
        </span>
        <span class="price-banner__divider" aria-hidden="true"></span>
        <span class="price-banner__item">
          Big Five <strong class="price-banner__price">garantizado</strong>
        </span>
        <span class="price-banner__divider" aria-hidden="true"></span>
        <span class="price-banner__item">
          Guías <strong class="price-banner__price">certificados</strong>
        </span>
      </div>
      <a href="/precios/" class="price-banner__cta">
        Ver todos los precios
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- ============================================================
       HERO — FONDO ÁMBAR (adaptación safari del patrón MC)
  ============================================================ -->
  <section class="hero" aria-label="Bienvenida a Safari Tanzania">
    <!-- Acacia deco top-right -->
    <div class="hero__daff hero__daff--tr" style="color:#2D4A22">
      <Fragment set:html={ACACIA_LARGE} />
    </div>

    <div class="container hero__inner">
      <!-- TEXT LEFT -->
      <div class="hero__text">
        <span class="chip chip--green">Serengeti · Ngorongoro · Tarangire</span>
        <h1 class="hero__title">La aventura de safari más espectacular de África</h1>
        <p class="hero__desc">Expediciones de vida salvaje en los parques nacionales de Tanzania: avistamiento de los Big Five, la Gran Migración del ñu, vuelos en globo aerostático sobre la sabana y caminatas bush con guías Masái.</p>
        <div class="hero__actions">
          <a href="/precios/" class="btn btn--primary btn--lg">Ver precios 2026</a>
          <a href="/como-llegar/" class="btn btn--outline btn--lg">Cómo llegar</a>
        </div>
        <div class="stats-row">
          <div class="stat"><strong>Big 5</strong><span>Animales icónicos</span></div>
          <div class="stat"><strong>16</strong><span>Parques nacionales</span></div>
          <div class="stat"><strong>365 días</strong><span>Safaris todo el año</span></div>
          <div class="stat"><strong>14,763 km²</strong><span>Serengeti</span></div>
        </div>
      </div>
      <!-- PHOTO RIGHT — MC style rounded + corner cutouts -->
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img src="https://images.unsplash.com/photo-1516426122078-c23e76319801?w=800&h=640&fit=crop&auto=format" alt="Paisaje del Serengeti al atardecer con acacias y cielo dorado en Tanzania" width="800" height="640" loading="eager">
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 1 — "Qué encontrarás en Safari Tanzania" — 4 PHOTO CARDS
  ============================================================ -->
  <section class="section section--gray" aria-labelledby="atracciones-title">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2 id="atracciones-title">Safari Tanzania es la puerta a la vida salvaje <em style="font-style:normal;color:#3D6B2E">más diversa del planeta</em></h2>
        <p>Desde las llanuras infinitas del Serengeti hasta el cráter del Ngorongoro, cada safari es una expedición única donde la naturaleza dicta el guion.</p>
      </div>

      <!-- 4 photo cards -->
      <div class="card-grid card-grid--4 animate-on-scroll">
        <a href="/safaris/" class="photo-card" aria-label="Tipos de Safari">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1523805009345-7448845a9e53?w=600&h=480&fit=crop&auto=format" alt="Vehículo de safari 4x4 en la sabana del Serengeti" width="600" height="480" loading="lazy">
          </div>
          <div class="photo-card__body">
            <p class="photo-card__title">Quiero explorar los tipos de safari</p>
            <div class="photo-card__arrow">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
        <a href="/actividades/" class="photo-card" aria-label="Actividades en Tanzania">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1504598318550-17eba1008a68?w=600&h=480&fit=crop&auto=format" alt="Globo aerostático sobre la sabana del Serengeti al amanecer" width="600" height="480" loading="lazy">
          </div>
          <div class="photo-card__body">
            <p class="photo-card__title">Quiero conocer todas las actividades</p>
            <div class="photo-card__arrow">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
        <a href="/hospedaje/" class="photo-card" aria-label="Hospedaje en Tanzania">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1621414050345-53db43f7e7ab?w=600&h=480&fit=crop&auto=format" alt="Vista del Cráter del Ngorongoro desde el borde" width="600" height="480" loading="lazy">
          </div>
          <div class="photo-card__body">
            <p class="photo-card__title">Me quiero hospedar en un lodge de safari</p>
            <div class="photo-card__arrow">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
        <a href="/como-llegar/" class="photo-card" aria-label="Cómo llegar a Tanzania">
          <div class="photo-card__img">
            <img src="https://images.unsplash.com/photo-1489392191049-fc10c97e64b6?w=600&h=480&fit=crop&auto=format" alt="Pueblo Masái con montañas al fondo en Tanzania" width="600" height="480" loading="lazy">
          </div>
          <div class="photo-card__body">
            <p class="photo-card__title">Necesito planear mi viaje a Tanzania</p>
            <div class="photo-card__arrow">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 2 — INFO LIBRARY — 4 cards con preguntas frecuentes
  ============================================================ -->
  <section class="section section--gray" aria-labelledby="info-title" style="padding-top:0">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2 id="info-title">Sea cual sea tu duda sobre safaris, aquí tienes la respuesta</h2>
      </div>
      <div class="card-grid card-grid--4 animate-on-scroll delay-1">
        <a href="/safaris/" class="photo-card">
          <div class="photo-card__img photo-card__img--tall">
            <img src="https://images.unsplash.com/photo-1546182990-dffeafbe841d?w=600&h=480&fit=crop&auto=format" alt="León macho descansando en la sabana del Serengeti" width="600" height="480" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Vida salvaje</span>
            <p class="photo-card__title">¿Qué es un safari en Tanzania?</p>
            <div class="photo-card__arrow">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
        <a href="/precios/" class="photo-card">
          <div class="photo-card__img photo-card__img--tall">
            <img src="https://images.unsplash.com/photo-1535941339077-2dd1c7963098?w=600&h=480&fit=crop&auto=format" alt="Manada de cebras en las llanuras del Serengeti" width="600" height="480" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Precios 2026</span>
            <p class="photo-card__title">¿Cuánto cuesta un safari?</p>
            <div class="photo-card__arrow">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
        <a href="/como-llegar/" class="photo-card">
          <div class="photo-card__img photo-card__img--tall">
            <img src="https://images.unsplash.com/photo-1547970810-dc1eac37d174?w=600&h=480&fit=crop&auto=format" alt="Jirafa caminando al atardecer en Tanzania" width="600" height="480" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Acceso</span>
            <p class="photo-card__title">¿Cómo llegar a Tanzania?</p>
            <div class="photo-card__arrow">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
        <a href="/hospedaje/" class="photo-card">
          <div class="photo-card__img photo-card__img--tall">
            <img src="https://images.unsplash.com/photo-1557050543-4d5f4e07ef46?w=600&h=480&fit=crop&auto=format" alt="Elefante africano en el Parque Nacional Tarangire" width="600" height="480" loading="lazy">
          </div>
          <div class="photo-card__body">
            <span class="photo-card__tag">Hospedaje</span>
            <p class="photo-card__title">¿Hay lodges dentro de los parques?</p>
            <div class="photo-card__arrow">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 3 — BLOQUE DEFINITORIAL
  ============================================================ -->
  <section class="section" aria-labelledby="geo-title">
    <div class="container animate-on-scroll" style="max-width:860px">
      <h2 id="geo-title" style="margin-bottom:1.25rem">¿Qué es Safari Tanzania?</h2>
      <p style="font-size:1.05rem;margin-bottom:1rem">Safari Tanzania es un operador de expediciones de vida salvaje con sede en Arusha, la puerta de entrada a los parques nacionales más emblemáticos de África oriental. Organizamos safaris en el Serengeti (14,763 km²), el Cráter del Ngorongoro (Patrimonio de la Humanidad), el Parque Nacional Tarangire y el Lago Manyara, entre otros 16 parques y reservas del país.</p>
      <p style="font-size:1.05rem;margin-bottom:1rem">Nuestras expediciones incluyen avistamiento de los Big Five (león, leopardo, elefante, rinoceronte negro y búfalo cafre), la Gran Migración anual de 1.5 millones de ñus, vuelos en globo aerostático sobre la sabana y caminatas bush guiadas por miembros de comunidades Masái. Todos los safaris se realizan en vehículos Toyota Land Cruiser 4x4 con techo elevable para observación y fotografía.</p>
      <p style="font-size:1.05rem;margin-bottom:2rem">Tanzania alberga el 20% de la biomasa de grandes mamíferos de África en sus ecosistemas protegidos. A diferencia de otros destinos de safari, Tanzania mantiene vastas extensiones de territorio sin vallado artificial, permitiendo que los animales sigan sus rutas migratorias ancestrales a través de la sabana, los bosques de baobabs y las planicies alcalinas de los lagos del Valle del Rift.</p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap">
        <a href="/precios/" class="btn btn--primary">Ver precios y paquetes</a>
        <a href="/como-llegar/" class="btn btn--outline">Cómo llegar a Tanzania</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 3B — PHOTO GALLERY
  ============================================================ -->
  <section class="section section--gray" style="padding-top:0">
    <div class="container">
      <div class="section__header animate-on-scroll">
        <h2>Galería fotográfica</h2>
        <p>Las imágenes más impresionantes de la vida salvaje de Tanzania</p>
      </div>
      <div class="photo-gallery animate-on-scroll delay-1">
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="https://images.unsplash.com/photo-1516426122078-c23e76319801?w=800&h=450&fit=crop&auto=format" alt="Paisaje panorámico del Serengeti con acacias al atardecer" width="800" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="https://images.unsplash.com/photo-1546182990-dffeafbe841d?w=600&h=450&fit=crop&auto=format" alt="León macho con melena dorada en la sabana" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="https://images.unsplash.com/photo-1557050543-4d5f4e07ef46?w=600&h=450&fit=crop&auto=format" alt="Elefante africano caminando entre acacias en Tarangire" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="https://images.unsplash.com/photo-1523805009345-7448845a9e53?w=600&h=450&fit=crop&auto=format" alt="Vehículo safari 4x4 recorriendo la sabana del Serengeti" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="https://images.unsplash.com/photo-1504598318550-17eba1008a68?w=600&h=450&fit=crop&auto=format" alt="Globo aerostático sobrevolando el Serengeti al amanecer" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="https://images.unsplash.com/photo-1535941339077-2dd1c7963098?w=600&h=450&fit=crop&auto=format" alt="Manada de cebras en las llanuras del Serengeti" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item photo-gallery__item--wide">
          <img src="https://images.unsplash.com/photo-1547970810-dc1eac37d174?w=800&h=450&fit=crop&auto=format" alt="Jirafa solitaria al atardecer con cielo naranja en Tanzania" width="800" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="https://images.unsplash.com/photo-1621414050345-53db43f7e7ab?w=600&h=450&fit=crop&auto=format" alt="Vista aérea del Cráter del Ngorongoro" width="600" height="450" loading="lazy">
        </div>
        <div class="photo-gallery__item">
          <img src="https://images.unsplash.com/photo-1489392191049-fc10c97e64b6?w=600&h=450&fit=crop&auto=format" alt="Guerreros Masái con vestimenta tradicional en Tanzania" width="600" height="450" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 4 — "ESTAMOS AQUÍ PARA TI"
       AMBER CARDS ON DARK GREEN (MC: "We're here for you")
  ============================================================ -->
  <section class="section section--green bg-green" aria-labelledby="servicios-title" style="position:relative;overflow:hidden">
    <!-- Acacia decorations -->
    <div style="position:absolute;top:0;right:0;opacity:.2;pointer-events:none;color:#D4A017">
      <Fragment set:html={ACACIA_LARGE} />
    </div>
    <div style="position:absolute;bottom:0;left:-20px;opacity:.15;pointer-events:none;color:#D4A017;transform:rotate(180deg)">
      <Fragment set:html={ACACIA_LARGE} />
    </div>

    <div class="container">
      <div class="section__header animate-on-scroll" style="margin-bottom:2.5rem">
        <h2 id="servicios-title" style="color:#D4A017">Estamos aquí para tu aventura</h2>
      </div>
      <div class="service-cards animate-on-scroll delay-1">
        <div class="service-card">
          <svg class="service-card__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.62 10.79z"/>
          </svg>
          <p class="service-card__title">Información y reservas</p>
          <p class="service-card__desc">Consulta disponibilidad de safaris, paquetes y fechas directamente con nuestro equipo en Arusha.</p>
          <p style="font-size:1.3rem;font-weight:900;color:#2D4A22;margin-bottom:.25rem">+255 753 000 000</p>
          <span class="chip chip--green" style="font-size:.75rem">Atención de 6:00 a 18:00</span>
        </div>

        <div class="service-card">
          <svg class="service-card__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
