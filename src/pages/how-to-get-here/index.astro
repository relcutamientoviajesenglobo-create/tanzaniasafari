---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SafariTikTok from '../../components/SafariTikTok.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';

const lang = 'en';
const title = 'How to Get to Tanzania — Flights, Visas & Transport 2026';

const galleryImages = [
  { src: 'https://images.unsplash.com/photo-1540541338287-41700207dee6?w=600&h=400&fit=crop&auto=format', alt: 'Aerial view of Mount Kilimanjaro — gateway to Tanzania safari adventures' },
  { src: 'https://images.unsplash.com/photo-1516426122078-c23e76319801?w=600&h=400&fit=crop&auto=format', alt: 'Safari vehicle driving through the Tanzanian landscape from Arusha' },
  { src: 'https://images.unsplash.com/photo-1489392191049-fc10c97e64b6?w=600&h=400&fit=crop&auto=format', alt: 'Welcome arrival at an Arusha hotel ahead of a Tanzanian safari' },
  { src: 'https://images.unsplash.com/photo-1523805009345-7448845a9e53?w=600&h=400&fit=crop&auto=format', alt: '4x4 safari vehicle ready for the journey from Arusha to the Serengeti' },
  { src: 'https://images.unsplash.com/photo-1504598318550-17eba1008a68?w=600&h=400&fit=crop&auto=format', alt: 'Charter bush flight over the Great Rift Valley heading to the Serengeti' },
  { src: 'https://images.unsplash.com/photo-1535338454528-1b5c8e9b0d64?w=600&h=400&fit=crop&auto=format', alt: 'Serengeti landscape — the final destination after arriving in Tanzania' },
];
const description = 'Complete 2026 guide on how to get to Tanzania for your safari. Flight options, visa requirements, airport transfers, and ground transportation from Arusha to the Serengeti and beyond.';

const ACACIA_LARGE = `<svg viewBox="0 0 200 160" width="200" height="160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="93" y="90" width="14" height="60" rx="4" fill="currentColor" opacity="0.7"/><ellipse cx="100" cy="75" rx="65" ry="38" fill="currentColor"/><ellipse cx="100" cy="70" rx="50" ry="28" fill="currentColor" opacity="0.5"/><ellipse cx="70" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><ellipse cx="130" cy="80" rx="30" ry="22" fill="currentColor" opacity="0.6"/><circle cx="170" cy="25" r="16" fill="currentColor" opacity="0.3"/></svg>`;

const breadcrumbs = [
  { label: 'How to Get Here' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'TravelAction',
  name: 'How to Get to Tanzania',
  description: description,
  toLocation: {
    '@type': 'Place',
    name: 'Arusha, Tanzania',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Arusha',
      addressCountry: 'TZ',
    },
  },
};
---

<BaseLayout title={title} description={description} schema={schema} breadcrumbs={breadcrumbs} lang={lang}>
  <Header slot="header" lang={lang} />
  <Footer slot="footer" lang={lang} />

  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="chip chip--green">Travel Guide</span>
        <h1>How to Get to Tanzania</h1>
        <p>Everything you need to know about reaching Tanzania for your safari. From international flights and visa requirements to local transportation and the journey from Arusha to the national parks.</p>
        <div class="hero__actions">
          <a href="/prices/" class="btn btn--primary btn--lg">See 2026 Prices</a>
          <a href="/contact/" class="btn btn--outline btn--lg">Contact Us</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__photo-frame">
          <div class="hero__deco hero__deco--tr"></div>
          <div class="hero__deco hero__deco--bl"></div>
          <img
            src="https://images.unsplash.com/photo-1540541338287-41700207dee6?w=600&h=400&fit=crop"
            alt="Aerial view of Mount Kilimanjaro with safari vehicle on the road below"
            width="600"
            height="400"
            loading="eager"
            style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:inherit"
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Flights -->
  <section class="section section--gray">
    <div class="container">
      <h2 style="text-align:center;margin-bottom:.75rem">International Flights</h2>
      <p style="text-align:center;max-width:620px;margin:0 auto 3rem">Tanzania has two main international airports serving safari travelers. Most visitors fly into Kilimanjaro International, the closest gateway to the northern safari circuit.</p>

      <div class="card-grid" style="grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:2rem">
        <div style="background:white;border-radius:var(--radius-lg);padding:2rem;box-shadow:var(--shadow-card)">
          <span style="font-size:2rem;display:block;margin-bottom:.75rem">✈️</span>
          <h3 style="margin-bottom:.5rem">Kilimanjaro International Airport (JRO)</h3>
          <p style="font-size:.92rem;margin-bottom:1rem">The primary airport for northern Tanzania safaris. Located between Arusha and Moshi, approximately 46 km from Arusha city center.</p>
          <p style="font-size:.85rem;color:var(--mc-text-muted)"><strong style="color:var(--mc-green)">Major airlines:</strong> KLM, Qatar Airways, Ethiopian Airlines, Turkish Airlines, Kenya Airways. Most connections via Amsterdam, Doha, Addis Ababa, Istanbul, or Nairobi.</p>
        </div>
        <div style="background:white;border-radius:var(--radius-lg);padding:2rem;box-shadow:var(--shadow-card)">
          <span style="font-size:2rem;display:block;margin-bottom:.75rem">🛬</span>
          <h3 style="margin-bottom:.5rem">Julius Nyerere International Airport (DAR)</h3>
          <p style="font-size:.92rem;margin-bottom:1rem">Located in Dar es Salaam. Useful for southern circuit safaris (Selous/Nyerere, Ruaha). Domestic flights connect to Arusha and the Serengeti.</p>
          <p style="font-size:.85rem;color:var(--mc-text-muted)"><strong style="color:var(--mc-green)">Domestic connections:</strong> Precision Air, Coastal Aviation, and Auric Air operate frequent flights to northern circuit airstrips.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Visa Requirements -->
  <section class="section">
    <div class="container" style="max-width:800px">
      <h2 style="text-align:center;margin-bottom:.75rem">Visa Requirements</h2>
      <p style="text-align:center;max-width:620px;margin:0 auto 3rem">Most visitors need a visa to enter Tanzania. The process is straightforward with two main options.</p>

      <div style="display:flex;flex-direction:column;gap:1.25rem">
        <div style="background:var(--mc-sand);border-radius:var(--radius-md);padding:1.5rem;border-left:4px solid var(--mc-green-mid)">
          <h3 style="font-size:1.05rem;margin-bottom:.5rem">E-Visa (Recommended)</h3>
          <p style="font-size:.92rem">Apply online at the Tanzania Immigration website at least 2 weeks before travel. Processing takes 5-10 business days. Cost: $50 USD for most nationalities. Single-entry, valid for 90 days.</p>
        </div>
        <div style="background:var(--mc-sand);border-radius:var(--radius-md);padding:1.5rem;border-left:4px solid var(--mc-green-mid)">
          <h3 style="font-size:1.05rem;margin-bottom:.5rem">Visa on Arrival</h3>
          <p style="font-size:.92rem">Available at JRO and DAR airports. Bring your passport (valid 6+ months), a completed application form, and $50 USD in cash. Allow 30-60 minutes for processing. Not available to all nationalities.</p>
        </div>
        <div style="background:var(--mc-sand);border-radius:var(--radius-md);padding:1.5rem;border-left:4px solid var(--mc-amber)">
          <h3 style="font-size:1.05rem;margin-bottom:.5rem">Health Requirements</h3>
          <p style="font-size:.92rem">Yellow fever vaccination certificate required if arriving from an endemic country. Malaria prophylaxis strongly recommended. Consult your travel doctor 6-8 weeks before departure.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ground Transport -->
  <section class="section section--gray">
    <div class="container">
      <h2 style="text-align:center;margin-bottom:.75rem">Ground Transportation</h2>
      <p style="text-align:center;max-width:620px;margin:0 auto 3rem">Getting from the airport to the safari parks involves scenic drives through the Tanzanian landscape. All transfers are handled by our team.</p>

      <div class="service-cards" style="grid-template-columns:repeat(auto-fit,minmax(260px,1fr))">
        <div class="service-card">
          <span style="font-size:2.2rem">🚐</span>
          <h3 style="color:var(--mc-green)">Airport Transfers</h3>
          <p style="color:var(--mc-green);opacity:.85;font-size:.95rem">Complimentary pick-up from JRO airport to your Arusha hotel. Our driver will greet you at arrivals with a Tanzania Safari sign.</p>
        </div>
        <div class="service-card">
          <span style="font-size:2.2rem">🚙</span>
          <h3 style="color:var(--mc-green)">Safari Vehicles</h3>
          <p style="color:var(--mc-green);opacity:.85;font-size:.95rem">4x4 Toyota Land Cruisers with pop-up roofs for game viewing. Arusha to Serengeti is approximately 325 km (6-7 hour drive through stunning scenery).</p>
        </div>
        <div class="service-card">
          <span style="font-size:2.2rem">🛩️</span>
          <h3 style="color:var(--mc-green)">Bush Flights</h3>
          <p style="color:var(--mc-green);opacity:.85;font-size:.95rem">Optional charter flights from Arusha to Serengeti airstrips (1 hour vs. 7 hours by road). Scenic views of the Great Rift Valley and Ngorongoro Crater rim.</p>
        </div>
        <div class="service-card">
          <span style="font-size:2.2rem">📍</span>
          <h3 style="color:var(--mc-green)">Distances</h3>
          <p style="color:var(--mc-green);opacity:.85;font-size:.95rem">JRO to Arusha: 46 km (1 hr). Arusha to Tarangire: 120 km (2 hrs). Arusha to Ngorongoro: 190 km (4 hrs). Arusha to Serengeti: 325 km (7 hrs).</p>
        </div>
      </div>
    </div>
  </section>

  <PhotoGallery images={galleryImages} title="Getting to Tanzania" />
  <SafariTikTok category="general" lang="en" />

  <!-- CTA -->
  <section class="section section--green">
    <div class="container" style="text-align:center;position:relative">
      <div style="position:absolute;top:-30px;right:0;opacity:.12;pointer-events:none;color:#D4A017">
        <Fragment set:html={ACACIA_LARGE} />
      </div>
      <h2 style="color:white;margin-bottom:.75rem">Need Help Planning Your Trip?</h2>
      <p style="color:rgba(255,255,255,.85);margin-bottom:1.5rem;max-width:520px;margin-left:auto;margin-right:auto">Our team can assist with flight recommendations, visa guidance, and all ground transportation arrangements. We handle the logistics so you can focus on the adventure.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/prices/" class="btn btn--primary btn--lg">See 2026 Prices</a>
        <a href="/contact/" class="btn btn--outline-white btn--lg" style="border-color:white;color:white">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
